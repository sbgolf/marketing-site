# Netlify Function: audit request submission
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
STARTLINE_SITE_URL=https://startlinesites.com

# Optional but recommended: salt used for one-way IP hashing before storing audit request metadata.
STARTLINE_IP_HASH_SALT=

# Netlify Function: lead/customer notification email via Resend REST API
# Set one of these API key vars in production. STARTLINE_RESEND_API_KEY is supported as a project-scoped alias.
RESEND_API_KEY=
STARTLINE_RESEND_API_KEY=

# Recipient falls back to STARTLINE_ADMIN_EMAIL, then support@startlinesites.com when omitted.
STARTLINE_LEAD_NOTIFY_EMAIL=
STARTLINE_ADMIN_EMAIL=support@startlinesites.com

# Must be a sender/domain verified in Resend. Defaults to: StartLine Sites <support@startlinesites.com>
STARTLINE_NOTIFY_FROM="StartLine Sites <support@startlinesites.com>"

# Optional reply-to for customer-facing audit confirmation and kickoff emails.
STARTLINE_KICKOFF_REPLY_TO=support@startlinesites.com

# Netlify Function: Stripe deposit/final-invoice webhook automation
# Configure the Stripe endpoint to POST checkout.session.completed and invoice.paid events to:
# https://startlinesites.com/.netlify/functions/stripe-webhook
STRIPE_WEBHOOK_SECRET=
STRIPE_WEBHOOK_TOLERANCE_SECONDS=300
STARTLINE_STRIPE_WEBHOOK_MAX_BODY_BYTES=100000
STARTLINE_STRIPE_WEBHOOK_URL=https://startlinesites.com/.netlify/functions/stripe-webhook

# Netlify Function: server-created Stripe Checkout Sessions after audit submission
# Enables customer-specific deposit sessions, final invoice creation, and monthly subscription start.
STRIPE_SECRET_KEY=

# Netlify Function: internal launch billing trigger
# POST /.netlify/functions/start-launch-billing with Authorization: Bearer <token> and customer_record_id.
STARTLINE_LAUNCH_BILLING_TOKEN=

# Optional customer-facing kickoff email after a paid deposit.
# Email sends only when both URLs are set; otherwise deposit records remain kickoff_ready/ready_to_send.
STARTLINE_INTAKE_FORM_URL=
STARTLINE_ASSET_CHECKLIST_URL=
