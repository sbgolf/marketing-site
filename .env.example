# Netlify Function: audit request submission
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
STARTLINE_SITE_URL=https://startlinesites.com

# Optional but recommended: salt used for one-way IP hashing before storing audit request metadata.
STARTLINE_IP_HASH_SALT=

# Netlify Function: lead notification email via Resend REST API
# Set one of these API key vars in production. STARTLINE_RESEND_API_KEY is supported as a project-scoped alias.
RESEND_API_KEY=
STARTLINE_RESEND_API_KEY=

# Recipient falls back to STARTLINE_ADMIN_EMAIL, then support@startlinesites.com when omitted.
STARTLINE_LEAD_NOTIFY_EMAIL=
STARTLINE_ADMIN_EMAIL=support@startlinesites.com

# Must be a sender/domain verified in Resend. Defaults to: StartLine Sites <support@startlinesites.com>
STARTLINE_NOTIFY_FROM="StartLine Sites <support@startlinesites.com>"

# Netlify Function: Stripe deposit webhook automation
# Configure the Stripe endpoint to POST checkout.session.completed events to:
# https://startlinesites.com/.netlify/functions/stripe-webhook
STRIPE_WEBHOOK_SECRET=
STRIPE_WEBHOOK_TOLERANCE_SECONDS=300
STARTLINE_STRIPE_WEBHOOK_MAX_BODY_BYTES=100000
