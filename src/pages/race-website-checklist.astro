---
import Base from '../layouts/Base.astro';

const basePath = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const brandLogoHref = `${basePath}brand/startline-sites-primary-horizontal.svg`;

const checklistSections = [
  {
    title: 'Registration clarity',
    intro: 'Runners should know exactly where to register, what distance they are choosing, and what deadline or price window matters now.',
    checks: [
      'Primary register CTA is visible near the top of the homepage and repeated after key decision sections.',
      'CTA language makes it clear that checkout happens on your existing registration platform.',
      'Distances, dates, start times, price windows, and sell-out notes match the registration platform.',
      'There is no competing “learn more” path where the next logical step should be registration.'
    ]
  },
  {
    title: 'Mobile speed and usability',
    intro: 'Most runners will check details on a phone. The page needs to load quickly and make the next tap obvious.',
    checks: [
      'Hero image is compressed, properly sized, and not blocking the first CTA.',
      'Navigation, CTA buttons, accordions, and course links are easy to tap at small widths.',
      'Important details are readable without pinch-zooming or horizontal scrolling.',
      'Third-party embeds are limited or deferred so the first view stays fast.'
    ]
  },
  {
    title: 'Course and logistics confidence',
    intro: 'Before they register, runners look for proof that the event is real, organized, and worth planning around.',
    checks: [
      'Course map, elevation notes, aid stations, packet pickup, parking, and start/finish logistics are easy to find.',
      'Certified/BQ/PR-friendly claims are specific, factual, and supported where applicable.',
      'Travel, lodging, road closure, and spectator notes are grouped instead of scattered across PDFs.',
      'Race-week update areas are clearly labeled so urgent changes do not get buried.'
    ]
  },
  {
    title: 'FAQ gaps',
    intro: 'A good FAQ reduces hesitation and protects the race team from avoidable email volume.',
    checks: [
      'Refund, transfer, deferral, cancellation, weather, accessibility, stroller, dog, headphone, and packet pickup policies are covered.',
      'Answers are written for runners, not just copied from internal operations notes.',
      'FAQ content matches the registration platform, waiver, and race-week emails.',
      'High-stakes answers link to the exact page or policy runners need next.'
    ]
  },
  {
    title: 'Sponsor and partner visibility',
    intro: 'Sponsors should be visible without making the runner journey feel cluttered.',
    checks: [
      'Sponsor logos are grouped by tier with correct names, links, and mobile presentation.',
      'Title sponsors, charity partners, city/tourism partners, and local businesses each have appropriate context.',
      'Partner visibility is balanced with registration, schedule, and logistics priority.',
      'Sponsor sections are easy to screenshot or reference during renewal conversations.'
    ]
  },
  {
    title: 'SEO and schema foundation',
    intro: 'Search visibility starts with clear race language, crawlable pages, and structured event information.',
    checks: [
      'Page title, meta description, H1, and intro copy include the race name, location, distance, and year where appropriate.',
      'Core pages have clean URLs, canonical tags, internal links, and indexable content rather than image-only details.',
      'Event, FAQ, organization, and breadcrumb schema are considered where they fit the page.',
      'Course, registration, volunteer, charity, sponsor, and results pages are named in language runners actually search.'
    ]
  },
  {
    title: 'Analytics and registration intent tracking',
    intro: 'You should know which pages runners use and which CTAs send them toward registration.',
    checks: [
      'GA4 and Search Console are owned by the race or race organization, not a temporary vendor account.',
      'Registration CTA clicks are tracked separately from general outbound links.',
      'UTM usage is documented for email, social, sponsor, and paid campaigns.',
      'The team reviews top pages, device mix, search queries, and CTA clicks before major registration pushes.'
    ]
  },
  {
    title: 'Race-week update readiness',
    intro: 'The site needs a clear place for urgent information when runner questions spike.',
    checks: [
      'Homepage has a reusable announcement area for weather, packet pickup, parking, road closures, and schedule changes.',
      'Race-week updates include date/time stamps so runners can trust the latest information.',
      'Critical updates are mirrored in email/social, with the website acting as the stable source of truth.',
      'Someone owns the update process, permissions, and final approval path before race week arrives.'
    ]
  }
];

const quickWins = [
  'Move the main registration CTA above the fold and repeat it after course/logistics sections.',
  'Compress the largest hero image and remove any embed that delays the first useful view.',
  'Add an FAQ answer for the top five questions your team keeps answering by email.',
  'Create one race-week announcement block before you urgently need it.',
  'Confirm GA4, Search Console, and registration click tracking ownership now.'
];

const faqItems = [
  ['Is this checklist only for StartLine customers?', 'No. It is an evergreen planning checklist race directors can use before any website refresh, private audit, or outreach conversation.'],
  ['Do we have to replace RunSignup, Race Roster, Haku, or Active?', 'No. A strong race website can keep your existing registration platform in place and send runners there through clearer, tracked CTAs.'],
  ['How often should we review the checklist?', 'Review it before registration opens, again 60–90 days before race day, and once more before race-week communications begin.'],
  ['What if our race details are still changing?', 'Publish the stable information first, clearly label what is pending, and give race-week updates a dedicated home so changing logistics do not create confusion.']
];

const pageUrl = 'https://startlinesites.com/race-website-checklist/';
const articleJson = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: 'Race Website Checklist for Race Directors',
  description: 'An evergreen race website checklist covering registration clarity, mobile speed, logistics, FAQs, sponsors, SEO/schema, analytics, and race-week updates.',
  url: pageUrl,
  author: {
    '@type': 'Organization',
    name: 'StartLine Sites',
    url: 'https://startlinesites.com/'
  },
  publisher: {
    '@type': 'Organization',
    name: 'StartLine Sites',
    url: 'https://startlinesites.com/'
  },
  mainEntityOfPage: pageUrl
};
const faqJson = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map(([name, text]) => ({
    '@type': 'Question',
    name,
    acceptedAnswer: {
      '@type': 'Answer',
      text
    }
  }))
};
---
<Base
  title="Race Website Checklist for Race Directors — StartLine Sites"
  description="Use this race website checklist to review registration clarity, mobile speed, race logistics, FAQs, sponsor visibility, SEO/schema, analytics, and race-week updates."
  canonicalPath="/race-website-checklist/"
  includeMarketingSchema={false}
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(articleJson)} />
  <script is:inline type="application/ld+json" set:html={JSON.stringify(faqJson)} />
  <nav id="nav">
    <a href="/" class="brand" aria-label="StartLine Sites home"><img class="brand-mark" src={brandLogoHref} alt="StartLine Sites" width="1200" height="360" /></a>
    <div class="nav-links" id="navLinks"><a href="/#pricing">Pricing</a><a href="/after-year-one/">After year one</a><a href="/#audit">Private audit</a><a href="/race-website-checklist/">Checklist</a><a class="btn btn-accent" href="/#audit">Request private audit</a></div>
    <button class="hamburger" id="burger" aria-label="Menu" aria-controls="navLinks" aria-expanded="false"><span></span><span></span><span></span></button>
  </nav>

  <main id="main">
    <section class="checklist-hero">
      <div class="checklist-hero-inner reveal">
        <div>
          <div class="kicker">Race director checklist</div>
          <h1>Is your race website ready to turn interest into registration clicks?</h1>
          <p class="lead">Use this evergreen checklist to audit the public website layer runners see before they reach your registration platform. It covers the details that help runners find the race, trust the information, and take the next step.</p>
          <div class="hero-actions"><a class="btn btn-accent" href="#checklist">Start the checklist →</a><a class="btn btn-ghost" href="/#audit">Request a private audit</a></div>
        </div>
        <aside class="scorecard" aria-label="Checklist scorecard">
          <span>Quick score</span>
          <strong>8 website areas</strong>
          <p>Give each area a green, yellow, or red status. Any red item near registration, logistics, or race-week updates deserves attention before the next outreach push.</p>
        </aside>
      </div>
    </section>

    <section class="intro-strip" aria-label="How to use this checklist">
      <div class="intro-card reveal">
        <h2>How to use it</h2>
        <ol>
          <li><strong>Walk the site like a runner.</strong> Start on mobile, then try to register, find packet pickup, answer a policy question, and confirm race-week logistics.</li>
          <li><strong>Mark friction honestly.</strong> Green means clear today, yellow means usable but risky, and red means runners may leave or email the race team.</li>
          <li><strong>Fix the highest-intent path first.</strong> Prioritize the CTA, schedule, course, FAQ, and update areas before cosmetic changes.</li>
        </ol>
      </div>
    </section>

    <section id="checklist" class="checklist-section" aria-labelledby="checklist-title">
      <div class="section-head reveal"><div><div class="kicker">Website audit areas</div><h2 id="checklist-title">Eight checks before the next registration push.</h2></div><p class="lead">The goal is not a perfect website. The goal is a clear, fast, trustworthy website that answers the questions runners need answered before they click through to register.</p></div>
      <div class="checklist-grid stagger">
        {checklistSections.map((section, index) => (
          <article class="check-card">
            <div class="check-card-head"><span>{String(index + 1).padStart(2, '0')}</span><h3>{section.title}</h3></div>
            <p>{section.intro}</p>
            <ul>{section.checks.map((check) => <li>{check}</li>)}</ul>
          </article>
        ))}
      </div>
    </section>

    <section class="quick-wins" aria-labelledby="quick-wins-title">
      <div class="quick-wins-inner reveal">
        <div>
          <div class="kicker">If you only have one hour</div>
          <h2 id="quick-wins-title">Five practical fixes that usually make the site easier to use.</h2>
          <p>These are not guaranteed-growth promises. They are common cleanup moves that reduce confusion and make runner intent easier to measure.</p>
        </div>
        <ol>{quickWins.map((win) => <li>{win}</li>)}</ol>
      </div>
    </section>

    <section class="followup-cta" aria-labelledby="followup-title">
      <div class="followup-inner reveal">
        <span>Outreach follow-up asset</span>
        <h2 id="followup-title">Want StartLine to review your race website against this checklist?</h2>
        <p>Send the current race URL. We’ll look for the clearest registration, SEO, sponsor, and race-week readiness opportunities before recommending a private mockup only when there is a fit.</p>
        <a class="btn btn-accent" href="/#audit">Request a private race website audit →</a>
      </div>
    </section>

    <section class="checklist-faq" aria-labelledby="checklist-faq-title">
      <div class="section-head reveal"><div><div class="kicker">Checklist FAQ</div><h2 id="checklist-faq-title">Good to know before you share it with the race team.</h2></div><p class="lead">Use the checklist internally, in sponsor or board conversations, or as a prep step before a StartLine private audit.</p></div>
      <div class="faq-grid stagger">
        {faqItems.map(([question, answer]) => (
          <article>
            <h3>{question}</h3>
            <p>{answer}</p>
          </article>
        ))}
      </div>
    </section>
  </main>

  <footer><div class="foot"><div><div class="brand footbrand"><img class="brand-mark" src={brandLogoHref} alt="StartLine Sites" width="1200" height="360" /></div><p>Fast, SEO-optimized race websites for race directors — built for search, speed, and signups.</p></div><div><div class="foot-title">Product</div><ul><li><a href="/#pricing">Pricing</a></li><li><a href="/after-year-one/">After year one</a></li><li><a href="/race-website-checklist/">Race website checklist</a></li><li><a href="/#audit">Private audit</a></li></ul></div><div><div class="foot-title">Company</div><ul><li><a href="https://bostonmarathonqualifyingraces.com">BMQR</a></li><li><a href="/#why">Why us</a></li><li><a href="/#faq">FAQ</a></li></ul></div></div><div class="foot-bottom"><span>© 2026 StartLine Sites. From the team behind BMQR.</span><span>Built for search, speed, and signups.</span></div></footer>

  <script>
    import '../scripts/nav.ts';
    import '../scripts/smoothScroll.ts';
    import '../scripts/reveal.ts';
  </script>
</Base>

<style>
nav{position:fixed;top:0;left:0;right:0;z-index:1000;display:flex;align-items:center;justify-content:space-between;padding:18px clamp(20px,5vw,56px);transition:all .3s ease}nav.scrolled{padding:12px clamp(20px,5vw,56px);background:rgba(250,250,247,.82);backdrop-filter:blur(18px) saturate(140%);box-shadow:0 1px 0 var(--line)}nav.menu-open{z-index:1200;background:var(--paper);box-shadow:0 1px 0 var(--line)}.brand-mark{display:block;width:168px;height:auto}.nav-links{display:flex;align-items:center;gap:24px}.nav-links a{font-weight:600;font-size:.92rem}.hamburger{display:none}.checklist-hero{padding:150px clamp(20px,5vw,56px) 92px;background:radial-gradient(circle at top right,rgba(31,184,196,.16),transparent 36%),linear-gradient(180deg,var(--paper),#fffaf4)}.checklist-hero-inner{max-width:var(--maxw);margin:0 auto;display:grid;grid-template-columns:1.08fr .62fr;gap:54px;align-items:center}.checklist-hero h1{font-size:clamp(2.9rem,6vw,5.6rem);max-width:13ch;margin-bottom:24px}.lead{font-size:1.08rem;line-height:1.65;color:rgba(14,23,41,.68)}.hero-actions{display:flex;flex-wrap:wrap;gap:12px;margin-top:32px}.scorecard{border:1px solid rgba(250,250,247,.14);border-radius:32px;background:var(--ink);color:var(--paper);padding:34px;box-shadow:0 32px 90px rgba(14,23,41,.18)}.scorecard span{font:800 .72rem/1.2 "JetBrains Mono",monospace;letter-spacing:.14em;text-transform:uppercase;color:var(--gold)}.scorecard strong{display:block;font-family:"Instrument Serif",serif;font-size:2.6rem;line-height:1.02;margin:18px 0}.scorecard p{color:rgba(250,250,247,.72);line-height:1.65}.intro-strip{padding:0 clamp(20px,5vw,56px) 96px;background:#fffaf4}.intro-card{max-width:var(--maxw);margin:0 auto;border:1px solid var(--line);border-radius:30px;background:#fff;padding:clamp(24px,4vw,38px);box-shadow:0 20px 65px rgba(14,23,41,.07);display:grid;grid-template-columns:.36fr 1fr;gap:28px}.intro-card h2{font-size:2.4rem}.intro-card ol{display:grid;gap:14px;color:rgba(14,23,41,.72);padding-left:20px}.intro-card li strong{color:var(--ink)}.checklist-section,.checklist-faq{padding:96px clamp(20px,5vw,56px);background:var(--paper)}.checklist-grid{max-width:var(--maxw);margin:46px auto 0;display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:20px}.check-card{border:1px solid var(--line);border-radius:28px;background:#fff;padding:26px;box-shadow:0 18px 55px rgba(14,23,41,.06)}.check-card-head{display:flex;gap:14px;align-items:flex-start;border-bottom:1px solid var(--line);padding-bottom:16px;margin-bottom:16px}.check-card-head span{font:800 .78rem/1 "JetBrains Mono",monospace;color:#fff;background:var(--accent);border-radius:999px;padding:9px 10px}.check-card h3{font-size:1.8rem}.check-card p{color:rgba(14,23,41,.68);line-height:1.62;margin-bottom:16px}.check-card ul{display:grid;gap:10px;padding-left:20px;color:rgba(14,23,41,.75)}.quick-wins{padding:96px clamp(20px,5vw,56px);background:linear-gradient(180deg,#0d1724,#111827);color:var(--paper)}.quick-wins-inner{max-width:var(--maxw);margin:0 auto;display:grid;grid-template-columns:.82fr 1fr;gap:44px;align-items:start}.quick-wins h2{font-size:clamp(2.4rem,5vw,4rem);margin-bottom:18px}.quick-wins p{color:rgba(250,250,247,.72);line-height:1.65}.quick-wins ol{counter-reset:wins;display:grid;gap:14px;list-style:none}.quick-wins li{counter-increment:wins;position:relative;border:1px solid rgba(250,250,247,.14);border-radius:20px;background:rgba(250,250,247,.07);padding:18px 18px 18px 58px;color:rgba(250,250,247,.82);line-height:1.55}.quick-wins li::before{content:counter(wins);position:absolute;left:18px;top:18px;width:26px;height:26px;border-radius:999px;background:var(--gold);color:var(--ink);display:grid;place-items:center;font-weight:800}.followup-cta{padding:96px clamp(20px,5vw,56px);background:#fffaf4}.followup-inner{max-width:920px;margin:0 auto;text-align:center;border:1px solid var(--line);border-radius:34px;background:#fff;padding:clamp(32px,5vw,54px);box-shadow:0 24px 80px rgba(14,23,41,.08)}.followup-inner span{font:800 .78rem/1.2 "JetBrains Mono",monospace;letter-spacing:.14em;text-transform:uppercase;color:var(--accent)}.followup-inner h2{font-size:clamp(2.4rem,5vw,4.4rem);margin:16px auto 18px;max-width:13ch}.followup-inner p{color:rgba(14,23,41,.68);line-height:1.65;max-width:68ch;margin:0 auto 28px}.faq-grid{max-width:var(--maxw);margin:46px auto 0;display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:18px}.faq-grid article{border:1px solid var(--line);border-radius:24px;background:#fff;padding:24px;box-shadow:0 14px 45px rgba(14,23,41,.05)}.faq-grid h3{font-family:"Plus Jakarta Sans";font-size:1.05rem;letter-spacing:0;line-height:1.35;margin-bottom:10px}.faq-grid p{color:rgba(14,23,41,.7);line-height:1.6}footer{background:var(--ink);color:var(--paper);padding:70px clamp(20px,5vw,56px) 30px}.foot{max-width:var(--maxw);margin:0 auto;display:grid;grid-template-columns:1.4fr .7fr .7fr;gap:40px}.footbrand{margin-bottom:20px}.foot p{color:rgba(250,250,247,.6);max-width:320px}.foot-title{font-weight:700;margin-bottom:16px;color:var(--gold)}.foot ul{list-style:none;display:grid;gap:10px}.foot a{color:rgba(250,250,247,.7)}.foot a:hover{color:#fff}.foot-bottom{max-width:var(--maxw);margin:46px auto 0;padding-top:24px;border-top:1px solid rgba(250,250,247,.12);display:flex;justify-content:space-between;gap:20px;color:rgba(250,250,247,.5);font-size:.88rem}@media(max-width:980px){.checklist-hero-inner,.intro-card,.quick-wins-inner,.foot{grid-template-columns:1fr}.checklist-grid,.faq-grid{grid-template-columns:1fr}.checklist-hero{padding-top:128px}.scorecard{max-width:520px}.foot-bottom{flex-direction:column}}@media(max-width:760px){nav{align-items:center;padding:14px 18px;background:rgba(250,250,247,.9);backdrop-filter:blur(14px)}.hamburger{display:flex;flex-direction:column;gap:5px;background:transparent;border:0;padding:10px}.hamburger span{display:block;width:24px;height:2px;background:var(--ink)}.nav-links{position:fixed;left:16px;right:16px;top:70px;display:none;flex-direction:column;align-items:stretch;gap:10px;padding:18px;border:1px solid var(--line);border-radius:20px;background:var(--paper);box-shadow:0 22px 70px rgba(14,23,41,.18)}.nav-links.open{display:flex}.nav-links .btn{justify-content:center}.checklist-hero{padding:116px 18px 62px}.intro-strip,.checklist-section,.quick-wins,.followup-cta,.checklist-faq{padding-left:18px;padding-right:18px}.hero-actions .btn{width:100%;justify-content:center}.check-card,.intro-card,.followup-inner{border-radius:22px}.foot{gap:28px}}
</style>
