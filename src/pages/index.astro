---
import Base from '../layouts/Base.astro';
const basePath = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const brandLogoHref = `${basePath}brand/startline-sites-primary-horizontal.svg`;
const communityRaceImageHref = `${basePath}images/community-road-race-before-after.jpg`;
const performanceRaceImageHref = `${basePath}images/performance-road-race-before-after.jpg`;
const segmentFits = [
  {
    segment: 'Community races',
    fit: '5Ks, 10Ks, half marathons, charity runs, and hometown events that need race-day details, local trust, and a cleaner registration path in one mobile-friendly place.',
    focus: 'Clarify schedule, parking, packet pickup, FAQs, volunteers, and community story before runners leave for the registration platform.'
  },
  {
    segment: 'BQ and certified marathons',
    fit: 'Boston qualifiers, USATF-certified courses, and performance-focused road races where runners compare certification, elevation, pacers, timing, and price deadlines.',
    focus: 'Bring certification, BQ status, pace support, course proof, and registration calls-to-action above the fold without overstating results.'
  },
  {
    segment: 'Multi-distance weekends',
    fit: 'Marathon, half marathon, 10K, 5K, kids race, relay, expo, or challenge weekends where one platform listing can make the event feel harder to understand than it is.',
    focus: 'Organize distances, schedules, pricing windows, maps, lodging notes, and race-week logistics so each runner sees the right next step.'
  },
  {
    segment: 'Sponsor-heavy events',
    fit: 'Races with title sponsors, charity partners, local businesses, tourism groups, or city stakeholders that need visibility without cluttering the runner journey.',
    focus: 'Create polished sponsor, partner, and community sections that make support easy to see while keeping registration clear.'
  },
  {
    segment: 'Platform-hosted races',
    fit: 'Events already using RunSignup, Race Roster, Haku, Active, or a similar registration platform but needing a stronger marketing layer in front of checkout.',
    focus: 'Keep the registration and payment system in place while adding the SEO, story, trust, analytics, and tracked click path around it.'
  }
];
const proofPoints = [
  {
    title: 'Founder-reviewed before it ships.',
    copy: 'Steve reviews the race story, registration path, SEO basics, and launch handoff so the site is not just a template with swapped colors.'
  },
  {
    title: 'Built from BMQR search experience.',
    copy: 'StartLine uses practical race-search lessons from BMQR: runners compare course details, certification, timing, logistics, trust signals, and price deadlines before they register.'
  },
  {
    title: 'Sample audit before the sales decision.',
    copy: 'The private audit gives race directors a concise written review with runner-facing findings and a recommended next step before any deposit is requested.'
  },
  {
    title: 'Fictional examples, clearly labeled.',
    copy: 'Public before/after sections use generic races and synthetic assets. Real testimonials, logos, named case studies, and screenshots stay unpublished until Steve approves real assets.'
  },
  {
    title: 'Performance and SEO discipline included.',
    copy: 'Every build is structured around fast pages, mobile clarity, schema markup, Search Console, GA4, and tracked registration clicks — built for search, speed, and signups.'
  },
  {
    title: 'Your platform stays the source of payment truth.',
    copy: 'RunSignup, Race Roster, Haku, Active, and similar platforms keep handling registration and payments. StartLine strengthens the public website layer around that path.'
  }
];
---
<Base>
  <nav id="nav">
    <a href="#top" class="brand" aria-label="StartLine Sites home"><img class="brand-mark" src={brandLogoHref} alt="StartLine Sites" width="1200" height="360" /></a>
    <div class="nav-links" id="navLinks">
      <a href="#problem">Why us</a><a href="#templates">Templates</a><a href="#sponsors">Sponsors</a><a href="#fit">Who fits</a><a href="#how">How it works</a><a href="#timeline">Timeline</a><a href="#pricing">Pricing</a><a href="/after-year-one/">After year one</a><a href="/race-website-checklist/">Checklist</a><a href="#faq">FAQ</a><button class="btn btn-accent" data-scroll="audit">Private audit</button>
    </div>
    <button class="hamburger" id="burger" aria-label="Menu" aria-controls="navLinks" aria-expanded="false"><span></span><span></span><span></span></button>
  </nav>
  <main id="main">
    <section class="hero" id="top"><div class="hero-inner"><div class="hero-text reveal"><span class="eyebrow">For race directors</span><h1>Race websites built to turn <span class="ital">interest</span> into registrations.</h1><p class="lead">Fast, SEO-optimized race websites for race directors — designed to help runners find your race, trust the details, and click through to register.</p><div class="hero-cta"><button class="btn btn-accent" data-scroll="audit">Request a private race website audit</button><button class="btn btn-ghost" data-scroll="templates">Explore example templates</button></div><div class="trust"><div class="dots"><span class="dot"></span><span class="dot"></span><span class="dot"></span></div><span>Built for search, speed, and signups.</span></div></div><div class="reveal"><div class="demo-wrap"><div class="demo-browser"><div class="bw-bar"><span class="bd"></span><span class="bd"></span><span class="bd"></span><span class="url">oceanmarathon.com</span></div><div class="bw-content"><svg class="bw-mountains" viewBox="0 0 600 120" preserveAspectRatio="none"><path d="M0 120 L0 70 L100 30 L200 65 L320 25 L450 60 L550 30 L600 55 L600 120Z" fill="#0B0E13" opacity=".95"/></svg><div class="bw-hero-text"><div class="e">● September 20, 2026 · Oregon</div><div class="demo-title">Ocean<br/>Marathon</div><div class="sub">The marathon that follows the coast.</div><div class="cd"><div class="cd-u">112<small>Days</small></div><div class="cd-u">14<small>Hrs</small></div><div class="cd-u">22<small>Min</small></div></div></div></div></div><div class="lh-badge"><div class="ring"><svg viewBox="0 0 60 60"><circle class="bg" cx="30" cy="30" r="26"/><circle class="fg" cx="30" cy="30" r="26"/></svg><span class="score">98</span></div><div class="label"><b>Lighthouse Score</b>Performance · SEO · A11y</div></div></div></div></div></section>
    <section class="problem" id="problem"><div class="section-head reveal"><div><div class="kicker">The problem</div><h2>Three reasons runner interest never becomes registrations.</h2></div><p class="lead">Most race websites are either an aging WordPress site nobody's touched in years, or a registration platform listing pretending to be a homepage. Either way, interested runners leave before they trust the details and click through to register.</p></div><div class="bento"><div class="prob prob-1 reveal"><span class="num">01</span><h3>Google can't see you.</h3><p>No schema markup. No SEO content. Page-speed scores in the 30s. Runners searching for “fast fall marathon” land on someone else's race — not yours.</p><div class="rank-viz"><div class="q">“fast fall marathon”</div><div class="results"><div class="result"><span class="pos">#1</span>Competitor Race</div><div class="result"><span class="pos">#2</span>Another Competitor</div><div class="result"><span class="pos">#3</span>Race Calendar Listing</div><div class="result you"><span class="pos">#47</span>Your Race</div></div></div><span class="stat">Top race sites score 95+ on Lighthouse SEO</span></div><div class="prob prob-2 reveal"><span class="num">02</span><h3>It doesn't sell the race.</h3><p>No course story. No elevation profile. No qualifying info. The runner who's almost ready gets a form, not a reason.</p><span class="stat">3 seconds to make the case</span></div><div class="prob prob-3 reveal"><span class="num">03</span><h3>You can't capture the maybes.</h3><p>The runner who came to look but isn't ready to pay? Gone. No email capture, no retargeting.</p><span class="stat">~70% don't register that day</span></div></div></section>
    <section class="outcomes" id="outcomes" aria-labelledby="outcomes-title"><div class="outcomes-inner reveal"><div><div class="kicker">Director outcomes</div><h2 id="outcomes-title">Outcomes race directors care about before race week.</h2><p class="lead">StartLine Sites is built around the practical jobs your race website has to do: make registration easier to reach, answer runner questions earlier, make partners visible, and reduce the amount of website admin on your plate.</p></div><div class="outcome-grid">{[['More runners reach registration','Clear hero CTAs, registration deep-links, and tracked clicks help interested runners get to the platform you already use.'],['Fewer support questions','Schedule, parking, packet pickup, course, pricing, and FAQ content are structured so runners can self-serve before race week.'],['Better sponsor and community value','Sponsor, partner, charity, and local community sections give stakeholders visible placement without cluttering the registration path.'],['Less website admin','Template-based builds, hosted maintenance, content updates, and reporting keep the site simpler for race directors to operate.']].map(([title,copy])=><article class="outcome-card"><span>→</span><h3>{title}</h3><p>{copy}</p></article>)}</div></div></section>
    <section class="sponsor-value" id="sponsors" aria-labelledby="sponsor-value-title"><div class="section-head reveal"><div><div class="kicker">Sponsor value</div><h2 id="sponsor-value-title">A race site should help partners see what they are supporting.</h2></div><p class="lead">For sponsor-supported races, StartLine adds a clearer public story around partner tiers, logos, charity alignment, and community visibility — so your website can support renewal conversations without distracting runners from registration.</p></div><div class="sponsor-value-inner reveal"><article class="sponsor-showcase" aria-label="Fictional sponsor section example"><div class="showcase-head"><span>Fictional example</span><strong>Ocean City Half Marathon</strong></div><div class="tier-row title-tier"><div><span class="tier-label">Title partner</span><h3>Regional Health Partner</h3><p>Presented as the lead supporter of the race experience, not just a logo block.</p></div><div class="logo-block large">RHP</div></div><div class="mini-logo-grid" aria-label="Example sponsor tiers"><div><span>Gold sponsors</span><div class="logo-row"><b>Local Running Store</b><b>Harbor Hotel Group</b></div></div><div><span>Community partners</span><div class="logo-row"><b>City Parks Dept.</b><b>Volunteer Club</b></div></div><div><span>Charity partner</span><div class="charity-card"><strong>Community Charity Partner</strong><em>Race weekend fundraising visibility and volunteer CTA placement.</em></div></div></div></article><div class="sponsor-copy"><div class="sponsor-copy-card"><h3>Make tiers easy to explain.</h3><p>Group title, presenting, gold, community, charity, and in-kind partners in plain language with the right visual weight for each commitment level.</p></div><div class="sponsor-copy-card"><h3>Give logos useful context.</h3><p>Pair sponsor marks with short support notes, links, and mobile-friendly placement so partners are visible without turning the homepage into a wall of logos.</p></div><div class="sponsor-copy-card"><h3>Support renewal conversations.</h3><p>Clean partner sections, sponsor callouts, and post-launch update support make it easier to show where partners appeared during the race cycle — without promising specific revenue outcomes.</p></div></div></div></section>
    <section class="templates" id="templates"><div class="section-head reveal"><div><div class="kicker">The templates</div><h2>Three outreach-ready templates for the races directors are already trying to sell.</h2></div><p class="lead">Destination Major, Community, and Performance concepts are fictional/generic preview directions for private mockups: fast, structured, mobile-first pages with schema markup and conversion-focused registration paths. Trail and Charity archetypes remain future expansions, not the primary offer.</p></div><div class="tpl-grid"><article class="tpl-card reveal"><span class="label">Fictional preview</span><div class="preview-ocean"><div class="sun"></div><svg class="mt" viewBox="0 0 600 140" preserveAspectRatio="none"><path d="M0 140 L0 100 L80 50 L180 90 L300 35 L420 80 L520 45 L600 75 L600 140Z" fill="#1B2433" opacity=".7"/><path d="M0 140 L0 120 L100 80 L240 115 L380 70 L500 110 L600 90 L600 140Z" fill="#0B0E13"/></svg><div class="copy"><div class="e">● Destination Major</div><h3>Cinematic. Clear.<br/>Built for travelers.</h3></div></div><div class="info"><h4>Destination Major</h4><p>For races runners travel for. Emphasizes scenery, logistics, lodging context, and a direct path from inspiration to registration.</p></div></article><article class="tpl-card reveal"><span class="label">Fictional preview</span><div class="preview-performance" aria-label="Performance template road race homepage preview"><div class="perf-browser"><div class="perf-nav"><span class="perf-brand">Summit City Road Race</span><span>Course</span><span>Details</span><span class="perf-nav-cta">Register</span></div><div class="perf-hero"><div class="perf-copy"><div class="e">● Performance road race</div><h3>Fast. Certified.<br/>PR-ready.</h3><p>Fast certified course with clear pace details.</p></div><div class="perf-clock" aria-hidden="true"><span>42D</span><em>09H</em><small>Start countdown</small></div></div><div class="perf-register"><strong>Registration open</strong><span>Certified course · pace details</span><b>Register →</b></div><div class="perf-stats"><div><strong>320′</strong><span>Gain</span></div><div><strong>26.2</strong><span>Certified</span></div><div><strong>42</strong><span>Days to start</span></div></div><div class="perf-course"><span></span><span></span><span></span></div></div></div><div class="info"><h4>Performance</h4><p>For fast certified road races built around PRs, qualifying times, countdown urgency, course proof, and clear registration paths.</p></div></article></div><div class="tpl-row-2 stagger"><div class="tpl-mini community-mini" aria-label="Community template Maple Grove 5K mini-homepage preview"><div class="comm-browser"><div class="comm-top"><span class="comm-brand">Maple Grove 5K</span><span>Details</span><span>Sponsors</span><span class="comm-nav-cta">Register</span></div><div class="comm-hero"><div><div class="comm-eyebrow">Template preview · Maple Grove 5K</div><h3>Local race.<br/>Big turnout.<br/>Easy registration.</h3><p>A friendly homepage for families, first-timers, sponsors, and returning runners.</p></div></div><div class="comm-cta"><span>Registration open · Saturday, May 18</span><b>Register →</b></div><div class="comm-details"><span>5K + Kids Dash</span><span>Local sponsors</span><span>Packet pickup</span></div><div class="comm-sponsors" aria-label="Local sponsor logo placeholders"><span></span><span></span><span></span><span></span></div></div><div class="community-info"><div class="sub">Template preview</div><div class="ttl">Community</div><p>For community races, town 5Ks, school fundraisers, and seasonal events that need clear details, local trust, sponsor visibility, and easy registration.</p></div></div><div class="tpl-mini m2"><div><div class="ttl">Trail</div><div class="sub">Coming next</div></div></div><div class="tpl-mini m3"><div><div class="ttl">Charity</div><div class="sub">Coming next</div></div></div></div></section>
    <section class="proof community-before-after" id="mockups" aria-labelledby="community-before-after-title"><div class="section-head reveal"><div><div class="kicker">Fictional community before / after</div><h2 id="community-before-after-title">A clearer race-day homepage without changing your registration platform.</h2></div><p class="lead">Fictional outreach concept for a generic community road race. The before/after cards are illustrative placeholder proof only: they use synthetic assets and sample details until StartLine has Steve-approved real customer work to show.</p></div><div class="community-compare reveal"><article class="community-panel before-panel" aria-labelledby="before-community-title"><div class="compare-label">Fictional before</div><div class="legacy-page"><div class="legacy-photo"><img src={communityRaceImageHref} alt="Synthetic stock-style photo of runners at a small-town road race start" width="1200" height="800" loading="lazy" decoding="async" /></div><div class="legacy-body"><p class="legacy-url">oceancityhalf.com</p><h3 id="before-community-title">Ocean City Half Marathon</h3><p class="legacy-date">Sunday, May 3 · 8:00 AM</p><p>A friendly spring half marathon and 5K on neighborhood roads. Registration, packet pickup, parking, and course information are listed below.</p><div class="legacy-links" aria-label="Example legacy page links"><a href="#" aria-label="Example legacy registration link">Register here</a><a href="#">Course map PDF</a><a href="#">Volunteer info</a></div></div></div><ul class="compare-points"><li>Key sample race-day details exist, but runners have to scan for them.</li><li>Registration is present, not prioritized as the next step.</li><li>Thin headings and dated mobile layout leave SEO upside unused.</li></ul></article><article class="community-panel after-panel" aria-labelledby="after-community-title"><div class="compare-label after">Fictional after · Community template / Standard</div><div class="community-browser"><div class="community-bar"><span></span><span></span><span></span><strong>oceancityhalf.com</strong></div><div class="community-hero-card"><img src={communityRaceImageHref} alt="Synthetic stock-style image used in the Ocean City Half homepage concept" width="1200" height="800" loading="lazy" decoding="async" /><div class="community-hero-copy"><p>Ocean City Half · May 3, 2026</p><h3 id="after-community-title">A local race weekend made easy to choose.</h3><button class="btn btn-accent" data-scroll="audit">Request a private mockup →</button></div></div><div class="community-detail-grid" aria-label="Community template content modules"><div><strong>Start time</strong><span>8:00 AM half · 8:20 AM 5K</span></div><div><strong>Packet pickup</strong><span>Saturday 2–6 PM at City Park</span></div><div><strong>Parking</strong><span>Free lots within a 10-minute walk</span></div><div><strong>Registration</strong><span>Clear CTA to existing platform</span></div></div></div><ul class="compare-points after-points"><li><strong>Registration clarity:</strong> one primary CTA plus supporting details.</li><li><strong>Mobile UX:</strong> tap-friendly schedule, parking, course, and FAQ blocks.</li><li><strong>Sample race-day details:</strong> packet pickup, start times, parking, aid, and cutoffs.</li><li><strong>SEO/schema:</strong> structured event content for search and social previews.</li></ul></article></div></section>

    <section class="proof performance-before-after" id="performance-mockup" aria-labelledby="performance-before-after-title"><div class="section-head reveal"><div><div class="kicker">Fictional Performance/BQ before / after</div><h2 id="performance-before-after-title">For certified races, speed and trust need to show up before the register click.</h2></div><p class="lead">Fictional outreach concept for a generic fast road marathon. These cards are illustrative placeholder proof only, using sample details and synthetic assets until StartLine has Steve-approved real customer assets.</p></div><div class="performance-compare"><article class="perf-panel perf-before" aria-labelledby="before-performance-title"><div class="compare-label">Fictional before</div><div class="perf-legacy"><div class="legacy-bar">capitalcitymarathon.org</div><h3 id="before-performance-title">Capital City Marathon</h3><p class="perf-muted">Flat course · spring race · registration open</p><div class="perf-note">USATF certification, pacer groups, BQ details, and price deadlines live in separate PDFs and update posts.</div><div class="perf-link-list"><span>Register on platform</span><span>Course PDF</span><span>Race weekend info</span></div></div><ul class="compare-points"><li>Sample fast-course proof is present, but buried below the fold.</li><li>Pacer, certification, and BQ details are split across links.</li><li>Runners do not get one clear reason to commit now.</li></ul></article><article class="perf-panel perf-after" aria-labelledby="after-performance-title"><div class="compare-label after">Fictional after · Performance template</div><div class="perf-site-card"><img src={performanceRaceImageHref} alt="Synthetic stock-style photo of a fast road marathon pacing group" width="1400" height="933" loading="lazy" decoding="async" /><div class="perf-overlay"><span>capitalcitymarathon.org</span><h3 id="after-performance-title">Fast, certified, PR-ready.</h3><button class="btn btn-accent" data-scroll="audit">Request a private mockup →</button></div></div><div class="perf-proof-strip" aria-label="Performance template proof points"><span><strong>USATF certified</strong> course proof</span><span><strong>3:00–5:00</strong> pace groups</span><span><strong>BQ-focused</strong> runner info</span><span><strong>Register CTA</strong> above the fold</span></div><ul class="compare-points light"><li>Course certification, pacers, and timing proof become visible immediately.</li><li>Every register CTA deep-links to the existing platform and tracks intent.</li><li>Schema, metadata, and speed gates support search before race season.</li></ul></article></div></section>
    <section class="trust-proof" id="proof-points"><div class="section-head reveal"><div><div class="kicker">Proof without pretend testimonials</div><h2>What you can verify before StartLine has public customer proof.</h2></div><p class="lead">StartLine is not publishing fake quotes, invented customer logos, or named case studies. The proof available today is the operating approach: a founder-reviewed build, BMQR-informed race-search judgment, transparent sample deliverables, fictional/generic examples, and measurable technical discipline.</p></div><div class="trust-proof-grid stagger">{proofPoints.map((point, index)=><article class="trust-proof-card"><span>{String(index + 1).padStart(2, '0')}</span><h3>{point.title}</h3><p>{point.copy}</p></article>)}</div><p class="proof-note reveal"><strong>Blocked until approved:</strong> real testimonials, customer logos, named case studies, and real screenshots are intentionally not shown on this public page.</p></section>
    <section class="how" id="how"><div class="section-head reveal"><div><div class="kicker">How it works</div><h2>Four steps. Two weeks. One launch.</h2></div><p class="lead">We've productized everything. No agency back-and-forth, no estimates that drift.</p></div><div class="steps-wrap"><div class="steps-line"></div><div class="steps stagger">{['Pick your template','Complete the intake form','We build & you review','Launch on your domain'].map((t,i)=><div class="step"><div class="step-icon">0{i+1}</div><h3>{t}</h3><p>{['One discovery call. We recommend the template that fits your race archetype.','One form captures everything: course, distances, pricing, sponsors, schedule, FAQs.','Staging URL in days. One revision pass included. Founder reviews everything before it ships.','We wire DNS, you keep ownership. Site lives on your URL with SSL, GA4, schema markup.'][i]}</p><span class="time">{['15 min','20–30 min','7–14 days','~24 hrs'][i]}</span></div>)}</div></div></section>
    <section class="launch-timeline" id="timeline" aria-labelledby="launch-timeline-title"><div class="section-head reveal"><div><div class="kicker">First-year launch timeline</div><h2 id="launch-timeline-title">What happens after your deposit?</h2></div><p class="lead">The first-year package is a concrete race-cycle workflow, not an open-ended retainer. Timing depends on how quickly intake, assets, domain access, and review feedback are ready, but each step has a clear handoff.</p></div><div class="timeline-grid stagger">{[['01','Deposit received','Your first-year package is confirmed, deposit is recorded, and StartLine sends the kickoff links for intake, assets, and access.','Kickoff handoff'],['02','Intake completed','You submit race details, distances, pricing windows, schedule, FAQs, sponsors, registration links, and any available photos or logos.','Client input'],['03','Draft homepage/site direction','StartLine turns the intake into a first draft or staging direction with the recommended template, core sections, CTAs, and tracking plan.','Build phase'],['04','Review pass','You review the staged direction, flag factual fixes, and use the included revision pass or passes in your package scope.','Focused feedback'],['05','Launch handoff','StartLine connects the domain, SSL, analytics, Search Console, schema markup, and registration deep-links, then confirms the public site is ready.','Launch-ready'],['06','Race-cycle support','Support stays tied to the package: launch-critical fixes, included updates or reviews, tracking checks, and scoped race-cycle content support where your package includes it.','First-year scope']].map(([num,title,copy,label])=><article class="timeline-card"><span>{num}</span><h3>{title}</h3><p>{copy}</p><strong>{label}</strong></article>)}</div><p class="timeline-note reveal"><strong>Important:</strong> launch timing is fastest when intake and assets are complete at kickoff. StartLine confirms scope before deposit so first-year support is clear and bounded.</p></section>
    <section class="cred" id="why"><div class="cred-inner"><div class="reveal"><div class="kicker">Founder note</div><h2>A straightforward note from Steve.</h2><div class="founder-note"><p>I’m building StartLine Sites because race directors should not have to choose between an outdated homepage and a registration listing that does not fully sell the race.</p><p>My background with <strong>bostonmarathonqualifyingraces.com</strong> gives me a practical view into how runners research events: they look for course confidence, timing details, logistics, trust signals, and a registration path that feels clear on mobile. I bring that lens into each StartLine audit and build.</p><p>I won’t show fake testimonials, borrowed logos, or inflated case studies. Until real customer proof is approved, I’d rather earn trust by showing the process, sample deliverables, fictional examples, and the technical standards behind the work.</p><p>StartLine does not replace your registration platform or promise a guaranteed registration lift. My job is to make the public website layer faster, clearer, easier to find, and easier for interested runners to act on.</p><p class="signature">Steve at StartLine Sites</p></div></div><div class="measure reveal"><h3>What BMQR Experience Brings To StartLine</h3><div class="measure-grid">{[['Search','Runner search behavior'],['Trust','Race-detail clarity'],['Intent','Registration-ready pages'],['SEO','Structured race content'],['Ops','Operational handoff clarity'],['Focus','Built for directors and runners']].map(([v,l])=><div class="metric"><div class="v">{v}</div><div class="l">{l}</div></div>)}</div></div></div></section>
    <section class="built-for" id="fit" aria-labelledby="segment-fit-title"><div class="built-for-inner reveal"><div class="kicker centered">Who this is for</div><h2 id="segment-fit-title">A stronger marketing layer for race directors with details runners need to trust.</h2><p class="lead">StartLine Sites is a fit when your registration platform already handles checkout, but your public race website needs clearer SEO language, event context, sponsor value, and a faster route to the register click.</p><div class="segment-grid stagger">{segmentFits.map((item, index)=><article class="segment-card"><span class="segment-num">0{index+1}</span><h3>{item.segment}</h3><p>{item.fit}</p><div class="segment-focus"><strong>StartLine helps by:</strong><span>{item.focus}</span></div></article>)}</div><div class="fit-note"><strong>Not sure?</strong><span>The private audit is designed to confirm fit before a deposit. If the StartLine layer is not the highest-value next move, the audit still points to practical improvements.</span></div></div></section>
    <section class="pricing" id="pricing"><div class="section-head reveal"><div><div class="kicker">Pricing</div><h2>One-time first-year packages for one race cycle.</h2></div><p class="lead">Each package is a one-time first-year race-cycle build and support package that keeps your registration platform in place while improving the website layer that answers runner questions, highlights sponsors, and moves interested runners toward tracked registration clicks.</p></div><div class="price-grid">{[{key:'starter',n:'Starter',p:'$1,500',deposit:'$750 deposit',note:'One-time first-year package',d:'For smaller races that need a clearer register path and a dependable website foundation for this race cycle',f:['Template + content load','Registration deep-link','Schema markup + Search Console','GA4 + conversion tracking','One revision pass','Hosting on your domain for one year','First-year support for launch-critical fixes']},{key:'standard',n:'Standard',p:'$2,500',deposit:'$1,250 deposit',note:'One-time first-year package',d:'Recommended for races that want registration clarity, richer race details, and planned race-cycle updates',featured:true,f:['Everything in Starter','Custom course visualization','Photo gallery','Race-cycle content updates','Conversion review and recommendations','Quarterly SEO check + fixes']},{key:'premium',n:'Premium',p:'$4,500',deposit:'Reviewed proposal required before deposit',note:'One-time first-year package',d:'For larger race weekends that need deeper sponsor visibility, content support, and reporting during the first race cycle',proposalOnly:true,f:['Everything in Standard','Color/typography tuning','Copywriting pass','Two revision passes','Retargeting pixel setup','Sponsor logo management']}].map(t=><article class:list={['tier','reveal',{featured:t.featured}]} data-package-card={t.key}>{t.featured&&<span class="tier-tag">Recommended</span>}<h3>{t.n}</h3><div class="desc">{t.d}</div><div class="price"><span class="num">{t.p}</span><span class="per">first year</span></div><span class="package-note">{t.note}</span><span class="deposit">{t.proposalOnly ? 'Audit + proposal before any first-year package deposit' : `50% first-year package deposit to start: ${t.deposit}`}</span><ul>{t.f.map(x=><li>{x}</li>)}</ul><button class:list={['btn',t.featured?'btn-accent':'btn-ghost']} data-scroll="audit" data-package-tier={t.key}>{t.proposalOnly ? 'Request Premium proposal' : `Choose ${t.n}`}</button></article>)}</div><div class="after-year-one reveal" id="after-year-one"><div><div class="kicker">After year one</div><h3>Optional one-time services when your next race cycle needs them.</h3><p>No automatic retainer is required after launch year. Choose scoped services around registration opening, sponsor updates, SEO checks, analytics reviews, race-week tune-ups, or next-year rollover.</p><a class="after-year-link" href="/after-year-one/">See the full service menu →</a></div><div class="addon-grid">{[['Annual race rollover','Refresh next-year date, registration, schedule, sponsors, and homepage freshness.'],['Quarterly website updates','Handle scoped logistics, sponsor, content, and CTA changes during the race cycle.'],['SEO check + fixes','Review Search Console, indexing, metadata, schema, and internal links.'],['Analytics review','Summarize traffic, registration clicks, top pages, and next recommendations.'],['Pre-race conversion tune-up','Tighten CTAs, mobile clarity, FAQs, and trust signals 60–90 days out.'],['Sponsor visibility refresh','Improve sponsor tiers, logos, links, and community partner presentation.']].map(([item,copy])=><article class="addon-card"><strong>{item}</strong><span>{copy}</span></article>)}</div></div><div class="custom-note reveal"><strong>Need help choosing?</strong> Request the audit without picking a package, and we'll recommend the right first-year scope before you pay a deposit.</div></section>
    <section class="audit-path" id="audit-path" aria-labelledby="audit-path-title"><div class="section-head reveal"><div><div class="kicker">Private audit path</div><h2 id="audit-path-title">What happens after you request a private audit?</h2></div><p class="lead">The goal is to make the next step concrete before anyone pays a deposit: StartLine reviews the current race site, responds within 2 business days, and recommends a package only if there is a clear fit.</p></div><div class="audit-path-grid stagger">{[['01','Submit your race details','Send the race name, current site or registration URL, timeline, and anything we should know about this year’s goals.'],['02','We review it like a runner','We check registration clarity, mobile trust, SEO structure, sponsor/community visibility, FAQ gaps, page-speed signals, and where runners may hesitate.'],['03','You get a concise deliverable','Within 2 business days, you receive a private written review with top opportunities, runner-facing impact, a recommended next step, and a private mockup concept when a StartLine template fit is obvious.'],['04','Then choose whether to move forward','If the fit is strong, the audit points to the right first-year race-cycle package and optional deposit path. If not, you still leave with useful next steps — no pressure to buy.']].map(([num,title,copy])=><article class="audit-path-card"><span>{num}</span><h3>{title}</h3><p>{copy}</p></article>)}</div></section>
    <section class="sample-audit" id="sample-audit" aria-labelledby="sample-audit-title"><div class="sample-audit-inner reveal"><div class="sample-audit-copy"><div class="kicker">Example deliverable</div><h2 id="sample-audit-title">A private audit should feel useful before the sales conversation.</h2><p class="lead">This fictional example shows the kind of focused output a race director can expect: practical findings, runner-facing impact, a clear recommendation, and the optional next step. It is a generic sample, not a real customer audit.</p><button class="btn btn-ghost" data-scroll="audit">Request your version</button></div><article class="audit-sample-card" aria-label="Fictional sample private audit output"><div class="sample-head"><div><span>Fictional generic example</span><h3>Ocean City Half Marathon</h3></div><strong>Standard fit</strong></div><div class="sample-section"><h4>Top findings</h4>{['Registration link appears after several logistics sections on mobile.','Packet pickup, parking, and course map live in separate PDFs instead of one runner FAQ path.','Sponsor logos are present, but community partner value is not explained near the registration decision.'].map(item=><p>{item}</p>)}</div><div class="sample-section outcome"><h4>Recommended next move</h4><p>Review a Community template direction, then decide whether the Standard first-year race-cycle package is worth moving into deposit and kickoff. No deposit is required to receive the audit response.</p></div></article></div></section>
    <section class="audit" id="audit"><div class="audit-inner"><div class="audit-copy reveal"><div class="kicker gold">Private race website audit</div><h2>See how your race could look with a clearer path to <span class="ital">registration.</span></h2><p>Send us your race name and current URL. We'll review the page like a runner deciding whether to register, then respond within 2 business days with the clearest next moves and mockup fit.</p><p class="outcome-note">Every mockup direction is tied to specific outcomes we identify on your current site: clearer registration paths, stronger mobile trust, better SEO structure, faster pages, fewer unanswered runner questions, and sponsor/community trust opportunities. Public examples are fictional until real customer assets are approved.</p><div class="what-you-get"><div class="what-title">What you'll get back within 2 business days</div><ul>{['Top 3 opportunities to make the registration path clearer','Runner FAQ/support-question gaps','Sponsor and community trust opportunities','SEO/search visibility gaps','Mobile and speed blockers','Registration funnel friction','A clear recommended next step, including whether a deposit makes sense'].map(x=><li>{x}</li>)}</ul><p class="teaser"><em>No pressure: you can use the findings either way. We may include additional opportunities and a private mockup concept when there is a clear fit.</em></p></div></div><div class="audit-form-wrap reveal"><div class="report-mock"><div class="rm-head"><span>Private Audit</span><span class="pill">Mockup</span></div><div class="rm-title">Your Race · 2026</div>{[['Top Opportunities','3',''],['SEO','Review','warn'],['Mobile','Review','warn'],['Mockup Fit','Possible',''],['Next Step','Clear','']].map(([a,b,c])=><div class="rm-row"><span>{a}</span><span class:list={['v',c]}>{b}</span></div>)}</div><form class="audit-form" id="auditForm"><h3>Request a private audit</h3><p class="sub">Send the basics. We'll review/respond within 2 business days with a concise written audit; no sales call or deposit required.</p><input id="packageTier" name="packageTier" type="hidden" value="" /><div class="selected-package" id="selectedPackage" hidden>Selected first-year package: <strong id="selectedPackageLabel"></strong></div><div class="field"><label for="raceName">Race name</label><input id="raceName" name="raceName" type="text" placeholder="e.g., Ocean Marathon" required /></div><div class="field"><label for="currentUrl">Your current site or registration URL</label><input id="currentUrl" name="currentUrl" type="url" placeholder="https://..." required /></div><div class="field"><label for="auditName">Your name</label><input id="auditName" name="auditName" type="text" placeholder="First Last" required /></div><div class="field"><label for="auditEmail">Email</label><input id="auditEmail" name="auditEmail" type="email" placeholder="you@email.com" required /></div><div class="field"><label for="notes">Anything we should know? <span class="optional">Optional</span></label><textarea id="notes" name="notes" rows="3" maxlength="1200" placeholder="Race date, registration platform, timeline, or goals"></textarea></div><div class="field hp-field" aria-hidden="true"><label for="companyWebsite">Company website</label><input id="companyWebsite" name="companyWebsite" type="text" tabindex="-1" autocomplete="off" /></div><button type="submit" class="btn btn-accent">Request private audit →</button><div class="form-note">Expect a private email response with findings, a recommended next step, and an optional mockup direction if there is a fit.</div><div class="form-msg" id="formMsg" role="status" aria-live="polite"></div></form></div></div></section>
    <section class="faq" id="faq"><div class="faq-wrap"><div class="reveal"><div class="kicker">Good to know</div><h2>Questions, answered.</h2></div><div class="faq-list" id="faqList">{[['Do we have to switch from RunSignup or RaceRoster?','No. We deep-link to your existing registration platform. Your money flow stays exactly where it is.'],['Who owns the domain and the site?','You do. Always. We host the site on your domain — you register and own it.'],['Who owns GA4 and Search Console data?','You do. We configure Google Analytics 4 and Google Search Console tracking, but the Google accounts, properties, access, and data remain under your ownership.'],["What if I don't have logos or photos ready?","Bring what you have. We'll work with low-res versions while better assets get sourced."],['Is this a one-time first-year package?','Yes. Core packages are one-time first-year race-cycle packages. After year one, you can buy optional one-time services when you need rollover, SEO, analytics, sponsor, or conversion updates. See the full after-year-one service menu for the scoped options.'],['What support is included in the first year?','Package support is tied to the listed deliverables: launch-critical fixes, included revision passes, tracking setup, and package-specific race-cycle updates or reviews. We define the scope before deposit.'],['Can I see what the analytics look like?','Yes — every customer gets their own Google Analytics 4 property and Search Console setup.'],['What if my race is in a few weeks and I need this fast?','Starter goes live in 7 days if intake and assets are ready on day one.'],['Do you work with non-marathon races?','Yes. Any road race — 5K, 10K, half, marathon, and ultra.']].map(([q,a])=><div class="faq-item"><button class="faq-q" type="button">{q}<span class="pm"></span></button><div class="faq-a"><p>{a}</p></div></div>)}</div></div></section>
