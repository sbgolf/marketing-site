---
import Base from '../layouts/Base.astro';
const basePath = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const brandLogoHref = `${basePath}brand/startline-sites-primary-horizontal.svg`;
const requiredAssets = [
  ['Logo files', 'Best: SVG or EPS originals with horizontal, stacked, one-color, and light/dark versions. Okay: high-resolution transparent PNG. Send what you have: old site logo, shirt art, or race mark with a note that StartLine should recommend cleanup.', 'Example: race-logo-primary.svg and race-logo-white.png'],
  ['Hero and race photos', 'Best: 6–12 licensed race-day photos at 2000px+ wide, with preferred hero candidates marked. Okay: a smaller edited gallery with start, finish, course, runner, volunteer, and community moments. Send what you have: photographer contact, folder link, or note that current photos need approval.', 'Example: finish-line-crowd.jpg, course-ridge-mile-9.jpg'],
  ['Sponsor logos', 'Best: transparent SVG/PNG logos grouped by exact tier with display names, URLs, and usage permission. Okay: website URLs for each sponsor. Send what you have: sponsor list plus who can confirm final order and rights.', 'Example: Premier Sponsor — Example Running Store — https://example.com'],
  ['Course map and elevation', 'Best: certified map, GPX/route link, elevation, aid stations, road closures, parking, and start/finish notes. Okay: PDF/image map plus logistics notes. Send what you have: registration-page course text or an older map clearly labeled for review.', 'Example: marathon-course-map.pdf and elevation-profile.png'],
  ['Brand colors and fonts', 'Best: HEX colors, font names, and brand guide. Okay: screenshots or examples you like. Send what you have: “use StartLine recommendation” if there is no formal brand system.', 'Example: Primary #0E1729, Accent #FF4D3D, Font: Montserrat'],
  ['Registration URL and status', 'Best: official registration URL, platform name, open/closed/waitlist/access-code status, price/fee notes, and registration-policy dates. Okay: platform dashboard link plus public URL. Send what you have: the current link and a note if prices or status may change.', 'Example: RunSignup registration page URL; prices include fees; transfers close September 15'],
  ['Policies and legal copy', 'Best: refund, transfer, deferral, weather, cancellation, accessibility, privacy, waiver, and safety rules that match registration. Okay: registration-page policy copy. Send what you have: “policy unchanged from last year” plus the page where it appears.', 'Example: “No refunds after September 1; transfers allowed through September 15.”'],
  ['Access owners and permissions', 'Best: names/emails for domain/DNS, domain email, GA4, Search Console, Tag Manager, Meta pixel, registration platform, and final launch approver. Okay: “another board member owns this” with contact info. Send what you have: who to ask next — do not email passwords.', 'Example: Domain at GoDaddy; GA4 owned by director@example.com'],
];
---
<Base
  title="Launch Readiness Asset Hub — StartLine Sites"
  description="Post-deposit StartLine Sites asset and permission hub: gather best available logos, photos, maps, sponsor files, policies, registration details, and access owners without waiting for perfection."
  canonicalPath="/asset-checklist"
  includeMarketingSchema={false}
  noindex={true}
>
  <nav class="simple-nav" aria-label="Primary">
    <a href="/" class="brand" aria-label="StartLine Sites home"><img src={brandLogoHref} alt="StartLine Sites" width="1200" height="360" /></a>
    <div><a href="/intake">Launch Readiness Checklist</a><a href="/#audit">Request audit</a><a href="/#pricing">Pricing</a><a href="/sample-audit/">Sample audit</a></div>
  </nav>
  <main id="main" class="checklist-page">
    <section class="checklist-hero">
      <div class="hero-copy">
        <p class="kicker">Launch Readiness resource</p>
        <h1>Send the best available assets. We’ll sort the rest.</h1>
        <p class="lead">Use this after your deposit to gather one shared folder for logos, race-day photos, maps, sponsors, policies, registration truth, and access owners. You do not need perfect files to keep the build moving — label what is best, what is okay, and what still needs permission.</p>
        <div class="trust-row" aria-label="StartLine asset checklist progress">
          <span class="trust-item is-complete"><span class="trust-icon" aria-hidden="true">✓</span><span>Deposit received</span></span>
          <span class="trust-item is-next"><span class="trust-icon" aria-hidden="true">→</span><span>One folder shared with StartLine</span></span>
          <span class="trust-item"><span class="trust-icon" aria-hidden="true">→</span><span>Permissions and gaps tracked before launch</span></span>
        </div>
      </div>
      <aside class="time-card" aria-label="Asset preparation guidance">
        <span class="eyebrow">Asset readiness pass</span>
        <strong>Best / okay / send what you have</strong>
        <span>One organized folder is better than scattered emails. If a file is rough or permission is pending, label it clearly so StartLine can decide whether it is build-ready or a launch follow-up.</span>
      </aside>
    </section>

    <section class="prospect-card" aria-labelledby="prospect-card-title">
      <div>
        <p class="kicker">Still evaluating StartLine?</p>
        <h2 id="prospect-card-title">This hub is for post-deposit Launch Readiness.</h2>
        <p>If you have not requested an audit or received a package recommendation yet, start with the buyer resources below. They explain fit, pricing, and what a private audit includes before asset permissions or access-owner details are needed.</p>
      </div>
      <div class="prospect-actions" aria-label="Prospect resources">
        <a class="btn btn-accent" href="/#audit">Request a private audit →</a>
        <a class="btn btn-ghost" href="/#pricing">View pricing</a>
        <a class="btn btn-ghost" href="/sample-audit/">See sample audit</a>
      </div>
    </section>

    <section class="prep-card">
      <div>
        <p class="kicker">Assets can be rough</p>
        <h2>Share one folder, then keep the checklist moving.</h2>
        <p>No special upload workflow is needed here. Put available logos, photos, maps, sponsor files, policy docs, registration screenshots, and access-owner notes in one shared folder, then paste the link into Launch Readiness. If permission is pending, label the file “needs approval” instead of holding the whole folder.</p>
      </div>
      <a class="btn btn-ghost" href="/intake">Open Launch Readiness Checklist →</a>
    </section>

    <section class="checklist-workspace" aria-label="Customer asset checklist workspace">
      <aside class="next-card" aria-labelledby="next-card-title">
        <p class="kicker">What happens next</p>
        <h2 id="next-card-title">StartLine reviews assets and permissions together.</h2>
        <ol>
          <li><strong>Sort build-ready items:</strong> we use the best/okay/send-what-you-have labels to decide what can go into staging now.</li>
          <li><strong>Group permission gaps:</strong> if photo rights, sponsor approval, DNS, analytics, or registration access needs an owner, we send one focused follow-up list.</li>
          <li><strong>Protect launch:</strong> assets can start the build, but public launch waits on rights, final approver, registration truth, and safe account access.</li>
        </ol>
      </aside>

      <div class="checklist-content">
        <section class="folder-card">
          <h2>Recommended folder setup</h2>
          <p>Once StartLine has asked you to prepare Launch Readiness assets, create one shared folder and make sure StartLine Sites can view it. Use subfolders for best files, okay fallbacks, and permission-pending items when that helps. If there are private working files you do not want published, place them in a clearly labeled “Reference only” folder. Use clear folder names so logos, photos, course files, sponsor assets, policies, and access owners are easy to review during the build.</p>
          <ol>
            <li><strong>01 Logos & brand</strong> — race logo, marks, colors, fonts, brand guide.</li>
            <li><strong>02 Photos</strong> — hero candidates, race day, course, community, medals/shirts.</li>
            <li><strong>03 Course</strong> — maps, elevation, GPX/route links, aid station chart, certification notes.</li>
            <li><strong>04 Sponsors</strong> — sponsor logos grouped by tier plus links.</li>
            <li><strong>05 Content & policies</strong> — schedule, FAQs, refund/transfer/cancellation/weather rules.</li>
            <li><strong>06 Access notes</strong> — domain, analytics, Search Console, pixels, and platform owners.</li>
          </ol>
        </section>

        <section class="readiness-tier-card" aria-labelledby="readiness-tier-title">
          <div>
            <p class="kicker">How to label assets</p>
            <h2 id="readiness-tier-title">Best is ideal. Okay is useful. “Send what you have” prevents stalls.</h2>
          </div>
          <div class="tier-grid">
            <article><strong>Best</strong><span>Original files, high resolution, rights confirmed, and clearly named.</span></article>
            <article><strong>Okay</strong><span>Usable fallback files, older versions, or links that need light cleanup.</span></article>
            <article><strong>Send what you have</strong><span>Contacts, screenshots, old folders, or notes that tell StartLine who can approve the final version.</span></article>
          </div>
        </section>

        <section id="checklist" class="asset-grid" aria-label="Required assets">
          {requiredAssets.map(([title, spec, example]) => (
            <article class="asset-card">
              <h2>{title}</h2>
              <p>{spec}</p>
              <div><span>Example</span>{example}</div>
            </article>
          ))}
        </section>

        <section class="quality-card">
          <div>
            <h2>Quality guidelines</h2>
            <ul>
              <li>Use original files when possible. Screenshots of logos or photos are usually too small, but they are still useful as “send what you have” references.</li>
              <li>Photos should be licensed for your race to use on the public website; label anything that still needs photographer or committee approval.</li>
              <li>Sponsor logos should include the correct tier/order, display name, link destination, and usage rights.</li>
              <li>Course, pricing, registration status, and policy details should match your registration platform to avoid runner confusion.</li>
              <li>Do not email passwords. Name the owner who can grant delegated access or schedule a screenshare.</li>
              <li>If something is missing, write “not available yet” in Launch Readiness instead of delaying the whole form.</li>
            </ul>
          </div>
          <aside>
            <strong>Best launch speed</strong>
            <p>The build can start with usable source files and clear owner notes. Public launch waits on rights, registration truth, account access, and final approval.</p>
          </aside>
        </section>

        <section class="examples-card">
          <h2>Helpful extras if you have them</h2>
          <div class="chips">
            <span>Medal/shirt mockups</span><span>Charity partner copy</span><span>Hotel/travel links</span><span>Volunteer info</span><span>Past results</span><span>Press mentions</span><span>Runner FAQ notes</span><span>Accessibility notes</span><span>Parking maps</span><span>Finish festival details</span>
          </div>
        </section>
      </div>
    </section>
  </main>
  <footer class="simple-footer">© 2026 StartLine Sites. Built for search, speed, and signups.</footer>
</Base>

<style>
  .simple-nav{position:relative;z-index:2;display:flex;align-items:center;justify-content:space-between;gap:20px;padding:18px clamp(20px,5vw,56px);background:#071426;border-bottom:1px solid rgba(255,255,255,.1);box-shadow:0 14px 34px rgba(7,20,38,.16)}
  .brand{display:inline-flex;align-items:center;background:#fff;border-radius:18px;padding:8px 12px;box-shadow:0 10px 30px rgba(0,0,0,.18)}.brand img{display:block;width:168px;height:auto}.simple-nav div{display:flex;gap:18px;flex-wrap:wrap}.simple-nav a{font-weight:800;font-size:.92rem;color:rgba(255,255,255,.84)}.simple-nav .brand:hover{transform:translateY(-1px)}.simple-nav a:hover{color:#ff7557}
  .checklist-page{background:linear-gradient(180deg,#f5eadf 0,var(--paper) 34%,#fff 78%,var(--paper-2));padding:56px clamp(18px,5vw,56px) calc(96px + env(safe-area-inset-bottom));overflow-x:clip}.checklist-hero,.prospect-card,.prep-card,.checklist-workspace{max-width:var(--maxw);margin:0 auto}.checklist-hero{display:grid;grid-template-columns:minmax(0,1fr) 340px;gap:32px;align-items:end;margin-bottom:28px;color:#fff;background:radial-gradient(circle at 82% 8%,rgba(255,117,87,.2),transparent 32%),linear-gradient(180deg,#071426 0,#10213a 100%);border-radius:32px;padding:clamp(28px,5vw,48px);box-shadow:0 28px 90px rgba(14,23,41,.18)}.hero-copy{min-width:0}.checklist-hero h1{font-size:clamp(3.1rem,8vw,6.2rem);line-height:.9;margin-bottom:20px;letter-spacing:-.045em;color:#fff}.lead{font-size:clamp(1.05rem,2vw,1.3rem);color:rgba(250,250,247,.82);max-width:68ch}.checklist-hero .kicker{color:#ffb199}.eyebrow{display:block;color:#d9553d;font-size:.78rem;font-weight:900;letter-spacing:.1em;text-transform:uppercase;margin-bottom:10px}.trust-row{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:12px;margin-top:26px;max-width:840px}.trust-item{display:grid;grid-template-columns:auto minmax(0,1fr);align-items:center;gap:10px;min-height:52px;border-left:3px solid rgba(255,117,87,.72);background:rgba(255,255,255,.08);color:rgba(255,255,255,.9);font-weight:800;font-size:.92rem;line-height:1.25;padding:10px 12px;border-radius:16px;box-shadow:inset 0 0 0 1px rgba(255,255,255,.1)}.trust-icon{display:inline-grid;place-items:center;width:24px;height:24px;border-radius:999px;background:#fff4ed;color:#b94129;font-weight:900;line-height:1}.trust-item.is-next{border-left-color:#ffb199;background:rgba(255,244,237,.13)}.trust-item.is-next .trust-icon{background:#ff7557;color:#fff}.time-card{background:linear-gradient(145deg,#fff,#f8f1ea);color:var(--ink);border:1px solid rgba(255,255,255,.72);border-radius:var(--r-lg);padding:24px;box-shadow:0 28px 80px rgba(0,0,0,.24)}.time-card strong{display:block;font-size:1.45rem;line-height:1.1;margin-bottom:10px}.time-card span:last-child{display:block;color:rgba(14,23,41,.68);line-height:1.55}
  .prospect-card{display:grid;grid-template-columns:minmax(0,1fr) auto;gap:24px;align-items:center;background:rgba(255,255,255,.88);border:1px solid rgba(255,255,255,.8);border-radius:28px;padding:22px;margin-bottom:22px;box-shadow:0 16px 50px rgba(14,23,41,.08);backdrop-filter:blur(14px)}.prospect-card h2,.prep-card h2,.next-card h2{font-size:clamp(1.7rem,3vw,2.25rem);margin-bottom:8px}.prospect-card p,.prep-card p,.next-card li{color:rgba(14,23,41,.7);line-height:1.6}.prospect-actions{display:flex;flex-wrap:wrap;gap:10px;justify-content:flex-end}.prospect-actions .btn{padding:10px 14px;font-size:.9rem}.prospect-actions .btn-accent{background:transparent;color:var(--accent);border:1px solid rgba(217,85,61,.34);box-shadow:none}.prospect-actions .btn-ghost{background:rgba(255,255,255,.72)}.prep-card{display:flex;align-items:center;justify-content:space-between;gap:24px;background:linear-gradient(135deg,#fff,#fff4ed);border:1px solid rgba(217,85,61,.16);border-radius:28px;padding:24px;margin-bottom:24px;box-shadow:0 16px 50px rgba(14,23,41,.06)}
  .checklist-workspace{display:grid;grid-template-columns:minmax(0,1fr) 330px;gap:24px;align-items:start}.next-card{position:sticky;top:24px;grid-column:2;background:#0e1729;color:#fff;border:1px solid rgba(255,255,255,.12);border-radius:30px;padding:24px;box-shadow:0 24px 70px rgba(14,23,41,.2)}.next-card .kicker{color:#ffb199}.next-card h2{color:#fff}.next-card ol{display:grid;gap:16px;margin:18px 0 0;padding-left:22px}.next-card li{color:rgba(255,255,255,.78)}.next-card strong{color:#fff}.checklist-content{grid-column:1;grid-row:1;min-width:0}.folder-card,.readiness-tier-card,.quality-card,.examples-card{background:rgba(255,255,255,.96);border:1px solid rgba(14,23,41,.1);border-radius:30px;padding:clamp(22px,4vw,38px);box-shadow:0 24px 90px rgba(14,23,41,.08)}.folder-card,.readiness-tier-card,.asset-grid,.quality-card{margin-bottom:24px}.folder-card h2,.readiness-tier-card h2,.quality-card h2,.examples-card h2{font-size:clamp(1.9rem,3vw,2.35rem);margin-bottom:14px}.folder-card p{color:rgba(14,23,41,.7);max-width:72ch;margin-bottom:18px;line-height:1.6}.folder-card ol{display:grid;gap:10px;list-style:none;padding:0;margin:0}.folder-card li{padding:12px 14px;background:var(--paper);border-radius:16px;color:rgba(14,23,41,.78)}
  .tier-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:14px}.tier-grid article{border:1px solid rgba(217,85,61,.16);border-radius:20px;background:linear-gradient(145deg,#fff,#fff7f2);padding:18px}.tier-grid strong{display:block;color:#b94129;font-size:1.05rem;margin-bottom:8px}.tier-grid span{display:block;color:rgba(14,23,41,.72);line-height:1.5}
  .asset-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:18px}.asset-card{background:rgba(255,255,255,.96);border:1px solid rgba(14,23,41,.1);border-radius:24px;padding:24px;box-shadow:0 14px 45px rgba(14,23,41,.05)}.asset-card h2{font-size:clamp(1.55rem,2.6vw,1.85rem);margin-bottom:10px}.asset-card p{color:rgba(14,23,41,.72);margin-bottom:16px;line-height:1.58}.asset-card div{border-left:4px solid var(--accent);padding:10px 0 10px 14px;background:linear-gradient(90deg,rgba(255,77,61,.07),transparent);color:rgba(14,23,41,.74);line-height:1.5}.asset-card span{display:block;font-size:.72rem;text-transform:uppercase;letter-spacing:.18em;font-weight:800;color:var(--accent);margin-bottom:4px}
  .quality-card{display:grid;grid-template-columns:minmax(0,1fr) 280px;gap:28px;align-items:start}.quality-card ul{display:grid;gap:10px;color:rgba(14,23,41,.76);padding-left:20px;line-height:1.55}.quality-card aside{background:var(--ink);color:#fff;border-radius:22px;padding:22px}.quality-card aside strong{font-size:1.2rem}.quality-card aside p{color:rgba(250,250,247,.78);margin-top:8px;line-height:1.55}.chips{display:flex;flex-wrap:wrap;gap:10px}.chips span{display:inline-flex;padding:10px 14px;border-radius:999px;background:var(--paper);border:1px solid var(--line);font-weight:700;color:rgba(14,23,41,.76)}.simple-footer{padding:28px clamp(20px,5vw,56px);background:var(--ink);color:rgba(250,250,247,.78);text-align:center}
  @media(max-width:1080px){.trust-row{grid-template-columns:1fr}.trust-item{min-height:48px}.checklist-workspace{grid-template-columns:1fr}.next-card{position:relative;top:auto;grid-column:1;grid-row:auto}.checklist-content{grid-column:1;grid-row:auto}.tier-grid{grid-template-columns:1fr}.quality-card{grid-template-columns:1fr}}
  @media(max-width:760px){.simple-nav{align-items:flex-start;flex-direction:column}.simple-nav div{gap:12px}.brand img{width:150px}.checklist-page{padding:20px clamp(16px,4vw,24px) calc(120px + env(safe-area-inset-bottom));background:linear-gradient(180deg,#f5eadf 0,var(--paper) 66%,var(--paper-2))}.checklist-hero,.prospect-card{grid-template-columns:1fr}.checklist-hero{padding:30px 22px 26px;border-radius:28px;margin-bottom:24px}.checklist-hero h1{font-size:clamp(3rem,18vw,4.6rem)}.trust-row{gap:10px}.trust-item{font-size:.95rem;min-height:50px}.prospect-actions{justify-content:flex-start}.prospect-actions .btn{width:100%;justify-content:center}.prep-card{align-items:flex-start;flex-direction:column}.prep-card .btn{width:100%;justify-content:center}.asset-grid{grid-template-columns:1fr}.folder-card,.readiness-tier-card,.next-card,.quality-card,.examples-card{border-radius:24px}.folder-card,.readiness-tier-card,.quality-card,.examples-card,.asset-card{padding:20px}.quality-card aside{border-radius:18px}}
</style>
