---
import Base from '../layouts/Base.astro';
const basePath = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const brandLogoHref = `${basePath}brand/startline-sites-primary-horizontal.svg`;
---
<Base
  title="Launch Readiness Checklist — StartLine Sites"
  description="Post-deposit Launch Readiness Checklist for approved StartLine Sites projects: confirm scraped race facts, add private details, and flag launch dependencies."
  canonicalPath="/intake"
  includeMarketingSchema={false}
  noindex={true}
>
  <nav class="simple-nav" aria-label="Primary">
    <a href="/" class="brand" aria-label="StartLine Sites home"><img src={brandLogoHref} alt="StartLine Sites" width="1200" height="360" /></a>
    <div><a href="/asset-checklist">Asset checklist</a><a href="/access-guides">Access guides</a><a href="/staging-review">Staging review</a><a href="/#audit">Request audit</a><a href="/#pricing">Pricing</a><a href="/sample-audit/">Sample audit</a></div>
  </nav>
  <main id="main" class="intake-page">
    <section class="intake-hero">
      <div class="hero-copy">
        <p class="kicker">Post-deposit Launch Readiness Kit</p>
        <h1>Confirm what we found. Add what only you know.</h1>
        <p class="lead">Use this checklist after your deposit to turn StartLine’s public research into a build-ready source of truth. Confirm the basics, flag anything that changed, and choose “I don’t know yet” for technical items another account owner controls.</p>
        <div class="trust-row" aria-label="StartLine intake progress">
          <span class="trust-item is-complete"><span class="trust-icon" aria-hidden="true">✓</span><span>Current site reviewed</span></span>
          <span class="trust-item is-complete"><span class="trust-icon" aria-hidden="true">✓</span><span>Deposit received</span></span>
          <span class="trust-item is-next"><span class="trust-icon" aria-hidden="true">→</span><span>Build starts after essentials are confirmed</span></span>
        </div>
      </div>
      <aside class="time-card" aria-label="Estimated completion time">
        <span class="eyebrow">Readiness pass</span>
        <strong>Plan for 12–18 minutes</strong>
        <span>You are not expected to know every technical answer. “I don’t know yet” is useful because it tells us who to follow up with before launch.</span>
      </aside>
    </section>

    <section class="prospect-card" aria-labelledby="prospect-card-title">
      <div>
        <p class="kicker">Not a customer yet?</p>
        <h2 id="prospect-card-title">Start with the private audit path.</h2>
        <p>After deposit, this page turns your public race information, registration details, access owners, and launch approvals into one clean checklist. If you are still evaluating StartLine Sites, please request a private audit first instead of completing Launch Readiness.</p>
      </div>
      <div class="prospect-actions" aria-label="Prospect resources">
        <a class="btn btn-accent" href="/#audit">Request a private audit →</a>
        <a class="btn btn-ghost" href="/#pricing">View pricing</a>
        <a class="btn btn-ghost" href="/sample-audit/">See sample audit</a>
      </div>
    </section>

    <section class="prep-card">
      <div>
        <p class="kicker">Assets can be rough</p>
        <h2>Paste one folder link if you have it.</h2>
        <p>No file upload is needed here. Put available photos, logos, course maps, sponsor marks, policy docs, or folder links in one shared Drive, Dropbox, Box, or similar folder, then paste the link below. If assets are still with a photographer, sponsor chair, or old vendor, write that in the notes and we’ll keep it on the launch checklist.</p>
      </div>
      <a class="btn btn-ghost" href="/asset-checklist">Review asset checklist →</a>
    </section>

    <section class="intake-workspace" aria-label="Customer intake workspace">
      <aside class="next-card" aria-labelledby="next-card-title">
        <p class="kicker">What happens next</p>
        <h2 id="next-card-title">Build inputs first. Launch blockers later.</h2>
        <ol>
          <li><strong>Confirm public facts:</strong> we compare your answers against the site, registration platform, and any private mockup or audit notes.</li>
          <li><strong>Group follow-ups:</strong> if DNS, analytics, assets, or approver details are unknown, we send one short owner list instead of scattered asks.</li>
          <li><strong>Start staging:</strong> once race identity, date/location, registration truth, package scope, and usable assets are clear, the staging build begins.</li>
        </ol>
      </aside>

    <form id="customerIntakeForm" class="intake-form" novalidate>
      <input type="text" name="company_website" class="hp" tabindex="-1" autocomplete="off" aria-hidden="true" />
      <input type="hidden" name="landing_page" value="https://startlinesites.com/intake" />

      <div id="intakePrefillNotice" class="confirm-note" role="note">
        <strong>Confirm what we found, then fill the gaps.</strong>
        <p>This checklist is intentionally structured like a review pass. Confirm the public facts StartLine found, correct anything outdated, and use the “I don’t know yet” options so technical/access owners can be handled before launch.</p>
      </div>

      <fieldset aria-labelledby="race-details-title">
        <legend class="visually-hidden">Confirm public race facts</legend>
        <h2 id="race-details-title" class="fieldset-title">Confirm public race facts</h2>
        <p class="fieldset-help">These are the essentials runners will scan first. If StartLine has prefilled details from your current site or registration page, correct anything stale here.</p>
        <div class="grid two">
          <label><span class="field-label">Organization name</span><input name="organization_name" autocomplete="organization" placeholder="Example Race Events" /></label>
          <label><span class="field-label"><span class="required-label">Race name <span class="required-marker" aria-hidden="true">*</span></span></span><input name="race_name" autocomplete="off" placeholder="Example Marathon" required /></label>
          <label><span class="field-label"><span class="required-label">Your name <span class="required-marker" aria-hidden="true">*</span></span></span><input name="contact_name" autocomplete="name" placeholder="Race Director" required /></label>
          <label><span class="field-label"><span class="required-label">Email <span class="required-marker" aria-hidden="true">*</span></span></span><input name="contact_email" type="email" autocomplete="email" placeholder="director@example.com" required /></label>
          <label><span class="field-label">Phone (optional)</span><input name="contact_phone" type="tel" autocomplete="tel" placeholder="Best number if a quick call helps" /></label>
          <label><span class="field-label"><span class="required-label">Event date or target date <span class="required-marker" aria-hidden="true">*</span></span></span><input name="event_date" placeholder="October 18, 2026 or date TBD" required /></label>
          <label><span class="field-label">Event timezone</span><span class="field-hint">Write “I don’t know yet” if timing will follow local venue time.</span><input name="event_timezone" placeholder="America/Chicago, Central Time, local timezone, or I don’t know yet" /></label>
          <label><span class="field-label"><span class="required-label">Event location <span class="required-marker" aria-hidden="true">*</span></span></span><input name="event_location" placeholder="City, state / venue" required /></label>
          <label><span class="field-label">Current race website/domain</span><span class="field-hint">Public URL is enough for build. Domain/DNS access is handled below.</span><input name="current_domain" type="url" inputmode="url" placeholder="https://examplemarathon.com or current race page" /></label>
          <label><span class="field-label">Template preference</span><span class="field-hint">Leave as “unsure” if you want StartLine to recommend the best fit.</span><input name="template_preference" placeholder="Destination Major, Performance, Community, Trail, Charity, or unsure" /></label>
        </div>
      </fieldset>

      <fieldset aria-labelledby="registration-details-title">
        <legend class="visually-hidden">Confirm registration truth and race details</legend>
        <h2 id="registration-details-title" class="fieldset-title">Confirm registration truth and race details</h2>
        <p class="fieldset-help">This is the handoff runners trust most. Confirm the official platform, current open/closed/waitlist state, prices, fees, and any access-code or transfer rules so StartLine never points runners at the wrong action.</p>
        <div class="grid two">
          <label><span class="field-label"><span class="required-label">Registration URL <span class="required-marker" aria-hidden="true">*</span></span></span><input name="registration_url" type="url" inputmode="url" placeholder="https://runsignup.com/..." required /></label>
          <label><span class="field-label">Registration platform</span><input name="registration_platform" placeholder="RunSignup, Race Roster, Haku, UltraSignup, custom, etc." /></label>
          <label><span class="field-label">Current registration status</span><select name="registration_status">
            <option value="">Choose one if you know it</option>
            <option>Open</option>
            <option>Closed</option>
            <option>Sold out</option>
            <option>Waitlist</option>
            <option>Transfer-only</option>
            <option>Access code required</option>
            <option>I don’t know yet</option>
          </select></label>
          <label><span class="field-label">Price/fee confidence</span><select name="pricing_confidence">
            <option value="">Choose one if helpful</option>
            <option>Confirmed current prices include fees</option>
            <option>Confirmed base prices before provider fees</option>
            <option>Prices are changing soon</option>
            <option>I don’t know yet</option>
          </select></label>
        </div>
        <label><span class="field-label">Distances and pricing summary</span><textarea name="distances_pricing" rows="5" class="textarea-large" placeholder="Marathon $120; Half $95; 5K $35. Include price changes if known."></textarea></label>
        <label><span class="field-label">Course and logistics summary</span><textarea name="course_logistics" rows="5" class="textarea-large" placeholder="Start/finish, course type, aid stations, parking, packet pickup, cutoff times."></textarea></label>
        <label><span class="field-label">BQ, certification, and results notes</span><textarea name="bq_certification" rows="3" placeholder="USATF certification, Boston qualifier status, timing provider, results history, awards."></textarea></label>
        <label><span class="field-label">Schedule</span><textarea name="race_schedule" rows="5" class="textarea-large" placeholder="Packet pickup, race start times, awards, post-race events."></textarea></label>
      </fieldset>

      <fieldset aria-labelledby="content-assets-title">
        <legend class="visually-hidden">Assets, access owners, and launch approvals</legend>
        <h2 id="content-assets-title" class="fieldset-title">Assets, access owners, and launch approvals</h2>
        <p class="fieldset-help">Add what is easy now and choose “I don’t know yet” when another volunteer, vendor, registrar, or Google account owner needs to help. We use this to separate build inputs from launch blockers.</p>
        <label><span class="field-label">Sponsors and partners</span><textarea name="sponsors" rows="5" class="textarea-large" placeholder="Sponsor names, tiers, preferred order, URLs, usage rights, and required wording."></textarea></label>
        <label><span class="field-label">FAQs</span><textarea name="faqs" rows="5" class="textarea-large" placeholder="Refunds, transfers, headphones, parking, weather, deferrals, age limits."></textarea></label>
        <label><span class="field-label">Volunteer information</span><textarea name="volunteer_info" rows="3" placeholder="Volunteer registration link, roles, shift notes, or write not applicable."></textarea></label>
        <label><span class="field-label">Email capture preference</span><textarea name="email_capture" rows="3" placeholder="Newsletter/waitlist provider, audience, or write not needed."></textarea></label>
        <label><span class="field-label">Preferred hero image</span><span class="field-hint">Filename, folder note, or “choose best available.”</span><input name="identity_hero_image" placeholder="Hero filename or folder note" /></label>
        <label><span class="field-label">Shared assets folder link</span><span class="field-hint">Google Drive, Dropbox, Box, or another shared folder is fine. Leave blank if the folder is not ready yet.</span><input name="assets_link" type="url" inputmode="url" placeholder="Shared folder URL" /></label>
        <div class="readiness-grid" aria-label="Launch dependency status checks">
          <label><span class="field-label">Domain/DNS owner</span><span class="field-hint">Who can safely approve launch-time domain changes?</span><select name="domain_dns_status">
            <option value="">Choose one if helpful</option>
            <option>I control it</option>
            <option>Another team member controls it</option>
            <option>Current website vendor controls it</option>
            <option>I don’t know yet</option>
          </select></label>
          <label><span class="field-label">Domain email safety</span><span class="field-hint">This helps prevent launch work from breaking race email.</span><select name="domain_email_status">
            <option value="">Choose one if helpful</option>
            <option>We use email at this domain</option>
            <option>We do not use email at this domain</option>
            <option>Another owner needs to confirm</option>
            <option>I don’t know yet</option>
          </select></label>
          <label><span class="field-label">Analytics/Search ownership</span><span class="field-hint">Google Analytics or Search Console can be connected before launch if available.</span><select name="analytics_search_status">
            <option value="">Choose one if helpful</option>
            <option>I can grant access</option>
            <option>Another Google account owner can grant access</option>
            <option>We need StartLine to set this up fresh</option>
            <option>I don’t know yet</option>
          </select></label>
          <label><span class="field-label">Final approver</span><span class="field-hint">One named person keeps staging feedback from turning into committee drift.</span><input name="final_approver" placeholder="Name/email, same as me, or I don’t know yet" /></label>
        </div>
        <details class="optional-group">
          <summary>Optional notes for access owners</summary>
          <div class="optional-group-body">
            <label><span class="field-label">Analytics, DNS, and access notes</span><textarea name="analytics_access_notes" rows="5" class="textarea-large" placeholder="Who owns GA4/Search Console/domain/DNS today? Who can grant access? Any pixels or tags needed?"></textarea></label>
            <label><span class="field-label">Anything else we should know?</span><textarea name="optional_notes" rows="5" class="textarea-large" placeholder="Timeline, approvals, brand preferences, access needs, or page-change concerns."></textarea></label>
          </div>
        </details>
      </fieldset>

      <div class="submit-row">
        <button class="btn btn-accent" type="submit">Submit Launch Readiness Checklist</button>
        <p id="intakeStatus" class="status" role="status" aria-live="polite">Required fields are marked with an asterisk. “I don’t know yet” is okay for optional launch dependencies.</p>
      </div>
      <p class="support-fallback">If the form fails or a field does not fit your race, email <a href="mailto:support@startlinesites.com?subject=Customer%20intake%20fallback">support@startlinesites.com</a> with your race name and project link.</p>
    </form>
    </section>
  </main>
  <footer class="simple-footer">© 2026 StartLine Sites. Built for search, speed, and signups.</footer>

  <script is:inline>
    const form = document.getElementById('customerIntakeForm');
    const status = document.getElementById('intakeStatus');
    const button = form?.querySelector('button[type="submit"]');
    const prefillNotice = document.getElementById('intakePrefillNotice');
    const setStatus = (message, tone = '') => {
      status.textContent = message;
      status.dataset.tone = tone;
    };
    const setPrefillNotice = (message, tone = '') => {
      const paragraph = prefillNotice?.querySelector('p');
      if (paragraph) paragraph.textContent = message;
      if (prefillNotice) prefillNotice.dataset.tone = tone;
    };
    const applyPrefill = (prefill) => {
      Object.entries(prefill || {}).forEach(([name, value]) => {
        const field = form?.elements?.[name];
        if (!field || typeof value !== 'string' || field.value) return;
        field.value = value;
      });
    };
    const removeTokenFromAddressBar = () => {
      const url = new URL(window.location.href);
      if (!url.searchParams.has('token')) return;
      url.searchParams.delete('token');
      window.history.replaceState(window.history.state, '', `${url.pathname}${url.search}${url.hash}`);
    };
    const loadPrefill = async () => {
      const token = new URLSearchParams(window.location.search).get('token');
      if (!token) return;
      removeTokenFromAddressBar();
      setStatus('Checking for StartLine customer record suggestions…', 'loading');
      try {
        const response = await fetch(`/.netlify/functions/get-customer-intake-prefill?token=${encodeURIComponent(token)}`, {
          method: 'GET',
          headers: { accept: 'application/json' },
        });
        const body = await response.json().catch(() => ({}));
        if (!response.ok || !body.ok) throw new Error(body.error || 'We could not load StartLine customer record suggestions.');
        applyPrefill(body.prefill);
        const count = body.source?.fields?.length || Object.keys(body.prefill || {}).length;
        setPrefillNotice('We prefilled a few kickoff details from your StartLine customer record. Please review and edit anything that changed.', 'success');
        setStatus(count ? 'Prefill suggestions loaded. Required fields are still editable.' : 'No saved suggestions were available; please complete the intake manually.', count ? 'success' : '');
      } catch (error) {
        setPrefillNotice('We could not load saved StartLine customer record suggestions for this link. You can still complete the intake manually.', 'error');
        setStatus(error.message || 'Prefill was unavailable. Please complete the intake manually.', 'error');
      }
    };
    loadPrefill();
    form?.addEventListener('submit', async (event) => {
      event.preventDefault();
      if (!form.checkValidity()) {
        form.reportValidity();
        setStatus('Please complete the required fields, then submit again.', 'error');
        return;
      }
      const payload = Object.fromEntries(new FormData(form).entries());
      button.disabled = true;
      setStatus('Submitting your intake…', 'loading');
      try {
        const response = await fetch('/.netlify/functions/submit-customer-intake', {
          method: 'POST',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify({ ...payload, referrer: document.referrer || '' }),
        });
        const body = await response.json().catch(() => ({}));
        if (!response.ok || !body.ok) {
          const firstFieldError = body.fields ? Object.values(body.fields)[0] : null;
          throw new Error(firstFieldError || body.error || 'We could not submit the intake. Please try again or email support@startlinesites.com with your race name.');
        }
        form.reset();
        setStatus(body.message || 'Thanks — your intake was received. We’ll follow up if anything is missing.', 'success');
      } catch (error) {
        setStatus(error.message || 'We could not submit the intake. Please try again or email support@startlinesites.com.', 'error');
      } finally {
        button.disabled = false;
      }
    });
  </script>
</Base>

<style>
  .simple-nav{position:relative;z-index:2;display:flex;align-items:center;justify-content:space-between;gap:20px;padding:18px clamp(20px,5vw,56px);background:#071426;border-bottom:1px solid rgba(255,255,255,.1);box-shadow:0 14px 34px rgba(7,20,38,.16)}
  .brand{display:inline-flex;align-items:center;background:#fff;border-radius:18px;padding:8px 12px;box-shadow:0 10px 30px rgba(0,0,0,.18)}.brand img{display:block;width:168px;height:auto}.simple-nav div{display:flex;gap:18px;flex-wrap:wrap}.simple-nav a{font-weight:800;font-size:.92rem;color:rgba(255,255,255,.84)}.simple-nav .brand:hover{transform:translateY(-1px)}.simple-nav a:hover{color:#ff7557}
  .intake-page{background:linear-gradient(180deg,#f5eadf 0,var(--paper) 34%,#fff 78%,var(--paper-2));padding:56px clamp(18px,5vw,56px) calc(96px + env(safe-area-inset-bottom));overflow-x:clip}.intake-hero,.prospect-card,.prep-card,.intake-workspace{max-width:var(--maxw);margin:0 auto}.intake-hero{display:grid;grid-template-columns:minmax(0,1fr) 340px;gap:32px;align-items:end;margin-bottom:28px;color:#fff;background:radial-gradient(circle at 82% 8%,rgba(255,117,87,.2),transparent 32%),linear-gradient(180deg,#071426 0,#10213a 100%);border-radius:32px;padding:clamp(28px,5vw,48px);box-shadow:0 28px 90px rgba(14,23,41,.18)}.hero-copy{min-width:0}.intake-hero h1{font-size:clamp(3.1rem,8vw,6.2rem);line-height:.9;margin-bottom:20px;letter-spacing:-.045em;color:#fff}.lead{font-size:clamp(1.05rem,2vw,1.3rem);color:rgba(250,250,247,.82);max-width:68ch}.intake-hero .kicker{color:#ffb199}.eyebrow{display:block;color:#d9553d;font-size:.78rem;font-weight:900;letter-spacing:.1em;text-transform:uppercase;margin-bottom:10px}.trust-row{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:12px;margin-top:26px;max-width:840px}.trust-item{display:grid;grid-template-columns:auto minmax(0,1fr);align-items:center;gap:10px;min-height:52px;border-left:3px solid rgba(255,117,87,.72);background:rgba(255,255,255,.08);color:rgba(255,255,255,.9);font-weight:800;font-size:.92rem;line-height:1.25;padding:10px 12px;border-radius:16px;box-shadow:inset 0 0 0 1px rgba(255,255,255,.1)}.trust-icon{display:inline-grid;place-items:center;width:24px;height:24px;border-radius:999px;background:#fff4ed;color:#b94129;font-weight:900;line-height:1}.trust-item.is-next{border-left-color:#ffb199;background:rgba(255,244,237,.13)}.trust-item.is-next .trust-icon{background:#ff7557;color:#fff}.time-card{background:linear-gradient(145deg,#fff,#f8f1ea);color:var(--ink);border:1px solid rgba(255,255,255,.72);border-radius:var(--r-lg);padding:24px;box-shadow:0 28px 80px rgba(0,0,0,.24)}.time-card strong{display:block;font-size:1.25rem;margin-bottom:8px}.time-card span:not(.eyebrow){color:rgba(14,23,41,.72)}
