---
import '../styles/base.css';
const title = '[BRAND] — Race websites that drive registrations';
const description = 'Modern, SEO-optimized race websites built in 14 days. Built by the team behind bostonmarathonqualifyingraces.com. For race directors who want their site to actually drive signups.';
const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://brand-marketing-site.pages.dev';
const basePath = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const faviconHref = `${basePath}favicon.svg`;
const ogImageHref = `${siteUrl}${basePath}og-image.jpg`;
const orgJson = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: '[BRAND]',
  url: siteUrl,
  description: 'Modern race websites for race directors.',
  sameAs: ['https://bostonmarathonqualifyingraces.com']
};
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageHref} />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="icon" href={faviconHref} type="image/svg+xml" />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(orgJson)} />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <svg width="0" height="0" style="position:absolute" aria-hidden="true"><defs><linearGradient id="lhg" x1="0" y1="0" x2="1" y2="1"><stop offset="0%" stop-color="#1FB8C4"/><stop offset="100%" stop-color="#5BD96A"/></linearGradient></defs></svg>
    <slot />
  </body>
</html>
