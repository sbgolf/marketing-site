---
import '../styles/base.css';
const defaultTitle = 'StartLine Sites — Race websites built to turn interest into registrations';
const defaultDescription = 'Fast, SEO-optimized websites for race directors — designed to help runners find your race, trust the details, and click through to register.';
const {
  title = defaultTitle,
  description = defaultDescription,
  canonicalPath = '/',
  includeMarketingSchema = true,
  noindex = false,
} = Astro.props;
const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://startlinesites.com';
const basePath = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const normalizedCanonicalPath = canonicalPath.startsWith('/') ? canonicalPath.slice(1) : canonicalPath;
const pagePath = normalizedCanonicalPath ? `${basePath}${normalizedCanonicalPath}` : basePath;
const faviconHref = `${basePath}favicon.svg`;
const appleTouchIconHref = `${basePath}brand/startline-sites-social-avatar-1024x1024.png`;
const logoHref = `${siteUrl}${basePath}brand/startline-sites-crest-only.svg`;
const canonicalUrl = `${siteUrl}${pagePath}`;
const homeUrl = `${siteUrl}${basePath}`;
const ogImageHref = `${siteUrl}${basePath}og-image.jpg`;
const organizationId = `${canonicalUrl}#organization`;
const serviceId = `${canonicalUrl}#service`;
const orgJson = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  '@id': organizationId,
  name: 'StartLine Sites',
  url: homeUrl,
  logo: logoHref,
  description: 'Modern race websites for race directors.',
  sameAs: ['https://bostonmarathonqualifyingraces.com']
};
const serviceJson = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  '@id': serviceId,
  name: 'StartLine Sites race website design and SEO service',
  serviceType: 'Race website design, SEO, analytics, and conversion optimization',
  url: canonicalUrl,
  description,
  provider: { '@id': organizationId },
  areaServed: {
    '@type': 'Country',
    name: 'United States'
  },
  audience: {
    '@type': 'Audience',
    audienceType: 'Race directors and endurance event organizers'
  },
  offers: [
    {
      '@type': 'Offer',
      name: 'Starter race website package',
      price: '1500',
      priceCurrency: 'USD',
      url: `${canonicalUrl}#pricing`,
      availability: 'https://schema.org/InStock'
    },
    {
      '@type': 'Offer',
      name: 'Standard race website package',
      price: '2500',
      priceCurrency: 'USD',
      url: `${canonicalUrl}#pricing`,
      availability: 'https://schema.org/InStock'
    },
    {
      '@type': 'Offer',
      name: 'Premium race website package',
      price: '4500',
      priceCurrency: 'USD',
      url: `${canonicalUrl}#pricing`,
      availability: 'https://schema.org/InStock'
    }
  ]
};
const faqJson = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  '@id': `${canonicalUrl}#faq-schema`,
  mainEntity: [
    ['Do we have to switch from RunSignup or RaceRoster?', 'No. We deep-link to your existing registration platform. Your money flow stays exactly where it is.'],
    ['Who owns the domain and the site?', 'You do. Always. We host the site on your domain — you register and own it.'],
    ['Who owns GA4 and Search Console data?', 'You do. We configure Google Analytics 4 and Google Search Console tracking, but the Google accounts, properties, access, and data remain under your ownership.'],
    ["What if I don't have logos or photos ready?", "Bring what you have. We'll work with low-res versions while better assets get sourced."],
    ['Is there a required monthly retainer?', 'No. Core packages are one-time first-year race-cycle packages. After year one, optional services are available as one-time scoped work.'],
    ['What support is included in the first year?', 'Package support is tied to the listed deliverables, revision passes, tracking setup, and package-specific race-cycle updates or reviews.'],
    ['Can I see what the analytics look like?', 'Yes — every customer gets their own Google Analytics 4 property and Search Console setup.'],
    ['What if my race is in a few weeks and I need this fast?', 'Starter goes live in 7 days if intake and assets are ready on day one.'],
    ['Do you work with non-marathon races?', 'Yes. Any road race — 5K, 10K, half, marathon, and ultra.']
  ].map(([name, text]) => ({
    '@type': 'Question',
    name,
    acceptedAnswer: {
      '@type': 'Answer',
      text
    }
  }))
};
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex,nofollow" />}
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageHref} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <link rel="icon" href={faviconHref} type="image/svg+xml" />
    <link rel="apple-touch-icon" href={appleTouchIconHref} />
    {includeMarketingSchema && <script is:inline type="application/ld+json" set:html={JSON.stringify(orgJson)} />}
    {includeMarketingSchema && <script is:inline type="application/ld+json" set:html={JSON.stringify(serviceJson)} />}
    {includeMarketingSchema && <script is:inline type="application/ld+json" set:html={JSON.stringify(faqJson)} />}
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <svg width="0" height="0" style="position:absolute" aria-hidden="true"><defs><linearGradient id="lhg" x1="0" y1="0" x2="1" y2="1"><stop offset="0%" stop-color="#1FB8C4"/><stop offset="100%" stop-color="#5BD96A"/></linearGradient></defs></svg>
    <slot />
  </body>
</html>
